@using SchoolManagement.Application.DTOs.Vehicle
@model UpdateVehicleDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تعديل بيانات المركبة";
    Layout = "_Layout";
}

<style>
    .edit-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #b68b40 0%, #9e7536 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #0d6e6e;
            }

    .card-body {
        padding: 30px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group.full-width {
            grid-column: span 2;
        }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
    }

        .control-label i {
            margin-left: 8px;
            color: #b68b40;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #b68b40;
            box-shadow: 0 0 0 3px rgba(182, 139, 64, 0.1);
        }

        .form-control:read-only {
            background-color: #e9ecef;
            opacity: 0.8;
        }

    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: #b68b40;
    }

    .form-check-label {
        cursor: pointer;
        font-weight: 600;
        color: #495057;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-update {
        background: #b68b40;
        color: white;
    }

        .btn-update:hover {
            background: #9e7536;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

    .hint-text {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .readonly-field {
        background-color: #e9ecef;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }

        .button-group {
            flex-direction: column;
        }
    }
</style>

<div class="edit-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-edit"></i>
                @ViewData["Title"]
            </h2>
        </div>

        <div class="card-body">
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="CarName" class="control-label">
                            <i class="fas fa-language"></i> اسم المركبة (عربي) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CarName" class="form-control" />
                        <span asp-validation-for="CarName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CarNameEn" class="control-label">
                            <i class="fas fa-language"></i> Vehicle Name (English) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CarNameEn" class="form-control" />
                        <span asp-validation-for="CarNameEn" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="PlateNum" class="control-label">
                            <i class="fas fa-hashtag"></i> رقم اللوحة
                        </label>
                        <input asp-for="PlateNum" class="form-control" />
                        <span asp-validation-for="PlateNum" class="text-danger"></span>
                        <div class="hint-text">اتركه فارغاً إذا لم يكن متوفراً</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Color" class="control-label">
                            <i class="fas fa-palette"></i> اللون
                        </label>
                        <input asp-for="Color" class="form-control" />
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Model" class="control-label">
                            <i class="fas fa-calendar"></i> الموديل
                        </label>
                        <input asp-for="Model" class="form-control" />
                        <span asp-validation-for="Model" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Chasee" class="control-label">
                            <i class="fas fa-barcode"></i> رقم الشاصي
                        </label>
                        <input asp-for="Chasee" class="form-control" />
                        <span asp-validation-for="Chasee" class="text-danger"></span>
                        <div class="hint-text">رقم فريد لكل مركبة - لا يمكن تكراره</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="LicIssueDate" class="control-label">
                            <i class="fas fa-calendar-alt"></i> تاريخ إصدار الرخصة
                        </label>
                        <input asp-for="LicIssueDate" type="date" class="form-control" />
                        <span asp-validation-for="LicIssueDate" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="LicEndDate" class="control-label">
                            <i class="fas fa-calendar-times"></i> تاريخ انتهاء الرخصة
                        </label>
                        <input asp-for="LicEndDate" type="date" class="form-control" />
                        <span asp-validation-for="LicEndDate" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="DriveId" class="control-label">
                            <i class="fas fa-user"></i> السائق المسؤول
                        </label>
                        <select asp-for="DriveId" class="form-control" asp-items="ViewBag.Drivers">
                            <option value="">-- اختر السائق --</option>
                        </select>
                        <span asp-validation-for="DriveId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <div class="form-check">
                            <input asp-for="InStock" class="form-check-input" />
                            <label asp-for="InStock" class="form-check-label">
                                <i class="fas fa-check-circle"></i> المركبة متوفرة
                            </label>
                        </div>
                        <div class="hint-text">قم بتحديد هذا الخيار إذا كانت المركبة متوفرة للاستخدام</div>
                    </div>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn btn-update">
                        <i class="fas fa-save"></i> تحديث البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // التحقق من تاريخ انتهاء الرخصة بعد تاريخ الإصدار
            $('#LicIssueDate, #LicEndDate').on('change', function() {
                var issueDate = $('#LicIssueDate').val();
                var endDate = $('#LicEndDate').val();

                if (issueDate && endDate && endDate < issueDate) {
                    Swal.fire({
                        title: 'تحذير',
                        text: 'تاريخ انتهاء الرخصة يجب أن يكون بعد تاريخ الإصدار',
                        icon: 'warning',
                        confirmButtonColor: '#b68b40'
                    });
                    $('#LicEndDate').val('');
                }
            });
        });
    </script>
}