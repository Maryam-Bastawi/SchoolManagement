@using SchoolManagement.Application.DTOs.TransferType
@model List<GetTransferTypeDto>
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "إدارة أنواع التحويل";
    Layout = "_Layout";
}

<style>
    .index-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .header-card {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        border-radius: 15px;
        padding: 30px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.1);
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 20px;
    }

    .header-title h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .header-title h1 i {
            color: #b68b40;
            font-size: 2.2rem;
        }

    .btn-create {
        background: #b68b40;
        color: white;
        padding: 12px 30px;
        border-radius: 50px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-create:hover {
            background: transparent;
            border: 2px solid #b68b40;
            color: #b68b40;
            transform: translateY(-2px);
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .stat-card {
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 3px 15px rgba(0, 0, 0, 0.03);
        border: 1px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .stat-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #0d6e6e20 0%, #0a5a5a20 100%);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #0d6e6e;
    }

    .stat-content h3 {
        margin: 0;
        font-size: 0.9rem;
        color: #6c757d;
        font-weight: 600;
    }

    .stat-content .stat-number {
        font-size: 1.8rem;
        font-weight: 700;
        color: #0d6e6e;
        line-height: 1.2;
    }

    .table-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f8f9fa;
        color: #0d6e6e;
        font-weight: 700;
        padding: 18px 15px;
        text-align: center;
        border-bottom: 2px solid #0d6e6e;
    }

    td {
        padding: 15px;
        text-align: center;
        border-bottom: 1px solid #e9ecef;
    }

    .amount {
        font-weight: 700;
        color: #0d6e6e;
    }

    .action-buttons {
        display: flex;
        gap: 8px;
        justify-content: center;
    }

    .btn-action {
        width: 36px;
        height: 36px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-view {
        background: #17a2b8;
    }

    .btn-edit {
        background: #b68b40;
    }

    .btn-delete {
        background: #dc3545;
    }

    .btn-action:hover {
        transform: translateY(-2px);
        filter: brightness(110%);
    }

    .alert {
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideDown 0.3s ease;
    }

    .alert-success {
        background: #d4edda;
        border-right: 4px solid #155724;
        color: #155724;
    }

    .alert-error {
        background: #f8d7da;
        border-right: 4px solid #721c24;
        color: #721c24;
    }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="index-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success" id="successAlert">
            <i class="fas fa-check-circle"></i>
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error" id="errorAlert">
            <i class="fas fa-exclamation-circle"></i>
            @TempData["Error"]
        </div>
    }

    <div class="header-card">
        <div class="header-title">
            <h1>
                <i class="fas fa-exchange-alt"></i>
                @ViewData["Title"]
            </h1>
            <p>إدارة أنواع التحويل والمسارات المتاحة</p>
        </div>
        <a asp-action="Create" class="btn-create">
            <i class="fas fa-plus-circle"></i>
            إضافة نوع تحويل جديد
        </a>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-route"></i>
            </div>
            <div class="stat-content">
                <h3>إجمالي المسارات</h3>
                <div class="stat-number">@Model.Count</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div class="stat-content">
                <h3>بقيمة 1</h3>
                <div class="stat-number">@Model.Count(x => x.Exmount1.HasValue)</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <i class="fas fa-money-bill-wave"></i>
            </div>
            <div class="stat-content">
                <h3>بقيمة 2</h3>
                <div class="stat-number">@Model.Count(x => x.Exmount2.HasValue)</div>
            </div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center p-5">
            <i class="fas fa-route fa-4x" style="color: #b68b40; opacity: 0.5;"></i>
            <h3 class="mt-3">لا توجد أنواع تحويل</h3>
            <p class="text-muted">لم يتم إضافة أي أنواع تحويل بعد</p>
            <a asp-action="Create" class="btn btn-primary mt-3">إضافة نوع تحويل</a>
        </div>
    }
    else
    {
        <div class="table-card">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>المسار (عربي)</th>
                        <th>Route (English)</th>
                        <th>القيمة 1</th>
                        <th>القيمة 2</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Select((value, i) => new { i = i + 1, value }))
                    {
                        <tr>
                            <td>@item.i</td>
                            <td>@item.value.Route</td>
                            <td>@item.value.RouteEng</td>
                            <td>
                                @if (item.value.Exmount1.HasValue)
                                {
                                    <span class="amount">@item.value.Exmount1.Value.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                @if (item.value.Exmount2.HasValue)
                                {
                                    <span class="amount">@item.value.Exmount2.Value.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a asp-action="Details" asp-route-id="@item.value.Id" class="btn-action btn-view" title="عرض التفاصيل">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.value.Id" class="btn-action btn-edit" title="تعديل">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="javascript:void(0);" onclick="confirmDelete(@item.value.Id, '@item.value.Route')" class="btn-action btn-delete" title="حذف">
                                        <i class="fas fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<form id="deleteForm" method="post" style="display: none;">
    <input type="hidden" name="id" id="deleteId" />
</form>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);
        });

        function confirmDelete(id, name) {
            Swal.fire({
                title: 'تأكيد الحذف',
                text: `هل أنت متأكد من حذف "${name}"؟`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    $('#deleteId').val(id);
                    $('#deleteForm').attr('action', '/TransferType/Delete/' + id).submit();
                }
            });
        }
    </script>
}