@using SchoolManagement.Application.DTOs.Drive
@model CreateDriveDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "إضافة سائق جديد";
    Layout = "_Layout";
}

<style>
    .create-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }


    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #b68b40;
            }

    .card-body {
        padding: 30px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
    }

        .control-label i {
            margin-left: 8px;
            color: #0d6e6e;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #0d6e6e;
            box-shadow: 0 0 0 3px rgba(13, 110, 110, 0.1);
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-save {
        background: #0d6e6e;
        color: white;
    }

        .btn-save:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

    .hint-text {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 5px;
    }
</style>

<div class="create-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-plus-circle"></i>
                @ViewData["Title"]
            </h2>
        </div>

        <div class="card-body">
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group">
                    <label asp-for="DrvNm" class="control-label">
                        <i class="fas fa-language"></i> الاسم (عربي) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="DrvNm" class="form-control" placeholder="أدخل اسم السائق بالعربية" />
                    <span asp-validation-for="DrvNm" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="DrvNmEn" class="control-label">
                        <i class="fas fa-language"></i> Name (English) <span class="text-danger">*</span>
                    </label>
                    <input asp-for="DrvNmEn" class="form-control" placeholder="Enter driver name in English" />
                    <span asp-validation-for="DrvNmEn" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Mobil" class="control-label">
                        <i class="fas fa-phone-alt"></i> رقم الجوال
                    </label>
                    <input asp-for="Mobil" class="form-control" placeholder="أدخل رقم الجوال " />
                    <span asp-validation-for="Mobil" class="text-danger"></span>
                    <div class="hint-text">مثال: 01234567890</div>
                </div>

                <div class="form-group">
                    <label asp-for="LicEnd" class="control-label">
                        <i class="fas fa-id-card"></i> تاريخ انتهاء الرخصة
                    </label>
                    <input asp-for="LicEnd" type="date" class="form-control" />
                    <span asp-validation-for="LicEnd" class="text-danger"></span>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}