@using SchoolManagement.Application.DTOs.Drive
@model GetDriveDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تفاصيل السائق";
    Layout = "_Layout";
}

<style>
    .details-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }


    .details-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #b68b40;
            }

    .card-body {
        padding: 30px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 30px;
    }

    .info-item {
        padding: 15px;
        background: #f8f9fa;
        border-radius: 10px;
        border: 1px solid #e9ecef;
    }

        .info-item.full-width {
            grid-column: span 2;
        }

    .info-label {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .info-label i {
            color: #17a2b8;
            width: 20px;
        }

    .info-value {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0d6e6e;
    }

    .mobile-number {
        direction: ltr;
        display: inline-block;
        font-family: monospace;
        font-size: 1.1rem;
    }

    .license-status {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
    }

    .status-valid {
        background: #d4edda;
        color: #155724;
    }

    .status-expired {
        background: #f8d7da;
        color: #721c24;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 20px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-edit {
        background: #b68b40;
        color: white;
    }

        .btn-edit:hover {
            background: #9e7536;
            transform: translateY(-2px);
        }

    .btn-back {
        background: #6c757d;
        color: white;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

    @@media (max-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="details-container">
    <div class="details-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-info-circle"></i>
                @ViewData["Title"]
            </h2>
        </div>

        <div class="card-body">
            <div class="info-grid">
                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-hashtag"></i>
                        الرقم التعريفي
                    </div>
                    <div class="info-value">@Model.Id</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-language"></i>
                        الاسم (عربي)
                    </div>
                    <div class="info-value">@Model.DrvNm</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-language"></i>
                        Name (English)
                    </div>
                    <div class="info-value">@Model.DrvNmEn</div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-phone-alt"></i>
                        رقم الجوال
                    </div>
                    <div class="info-value">
                        @if (!string.IsNullOrEmpty(Model.Mobil))
                        {
                            <span class="mobile-number">@Model.Mobil</span>
                        }
                        else
                        {
                            <span class="text-muted">لا يوجد</span>
                        }
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-id-card"></i>
                        تاريخ انتهاء الرخصة
                    </div>
                    <div class="info-value">
                        @if (!string.IsNullOrEmpty(Model.LicEnd))
                        {
                            @Model.LicEnd
                        }
                        else
                        {
                            <span class="text-muted">غير محدد</span>
                        }
                    </div>
                </div>

                <div class="info-item">
                    <div class="info-label">
                        <i class="fas fa-check-circle"></i>
                        حالة الرخصة
                    </div>
                    <div>
                        @{
                            var licEndDate = DateTime.TryParse(Model.LicEnd, out DateTime licDate) ? licDate : (DateTime?)null;
                            var isExpired = licEndDate.HasValue && licEndDate.Value < DateTime.Today;
                        }
                        @if (licEndDate.HasValue)
                        {
                            if (isExpired)
                            {
                                <span class="license-status status-expired">
                                    <i class="fas fa-exclamation-circle"></i> منتهية
                                </span>
                            }
                            else
                            {
                                <span class="license-status status-valid">
                                    <i class="fas fa-check-circle"></i> سارية
                                </span>
                            }
                        }
                        else
                        {
                            <span class="text-muted">غير محدد</span>
                        }
                    </div>
                </div>
            </div>

            <div class="button-group">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit">
                    <i class="fas fa-edit"></i> تعديل
                </a>
                <a asp-action="Index" class="btn btn-back">
                    <i class="fas fa-arrow-right"></i> العودة للقائمة
                </a>
            </div>
        </div>
    </div>
</div>
