@using SchoolManagement.Domain.Entities
@model PaginationModel

@if (Model.TotalPages > 1)
{
    <div class="pagination-wrapper">
        <div class="pagination-container">
            <ul class="pagination">
                <!-- زر الصفحة السابقة -->
                @if (Model.HasPreviousPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action(Model.Action, "Area", new {
                            page = Model.CurrentPage - 1,
                            search = Model.SearchTerm,
                            pageSize = Model.PageSize
                        })">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                    </li>
                }

                <!-- أرقام الصفحات -->
                @{
                    int startPage = Math.Max(1, Model.CurrentPage - 2);
                    int endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 2);

                    if (startPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action(Model.Action, "Area", new { page = 1, search = Model.SearchTerm, pageSize = Model.PageSize })">1</a>
                        </li>
                        if (startPage > 2)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                    }

                    for (int i = startPage; i <= endPage; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action(Model.Action, "Area", new { page = i, search = Model.SearchTerm, pageSize = Model.PageSize })">@i</a>
                            </li>
                        }
                    }

                    if (endPage < Model.TotalPages)
                    {
                        if (endPage < Model.TotalPages - 1)
                        {
                            <li class="page-item disabled"><span class="page-link">...</span></li>
                        }
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action(Model.Action, "Area", new { page = Model.TotalPages, search = Model.SearchTerm, pageSize = Model.PageSize })">@Model.TotalPages</a>
                        </li>
                    }
                }

                <!-- زر الصفحة التالية -->
                @if (Model.HasNextPage)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action(Model.Action, "Area", new {
                            page = Model.CurrentPage + 1,
                            search = Model.SearchTerm,
                            pageSize = Model.PageSize
                        })">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>
                }
                else
                {
                    <li class="page-item disabled">
                        <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                    </li>
                }
            </ul>

            <div class="pagination-footer">
                <div class="pagination-info">
                    عرض @Model.StartRecord - @Model.EndRecord من @Model.TotalCount
                </div>

                <div class="page-size-selector">
                    <span>عرض:</span>
                    <select id="pageSizeSelect" class="form-select-sm">
                        <option value="5" selected="@(Model.PageSize == 5)">5</option>
                        <option value="10" selected="@(Model.PageSize == 10)">10</option>
                        <option value="25" selected="@(Model.PageSize == 25)">25</option>
                        <option value="50" selected="@(Model.PageSize == 50)">50</option>
                        <option value="100" selected="@(Model.PageSize == 100)">100</option>
                    </select>
                    <span>عناصر</span>
                </div>
            </div>
        </div>
    </div>
}

<style>
    .pagination-wrapper {
        display: flex;
        justify-content: center;
        margin-top: 40px;
        margin-bottom: 30px;
    }

    .pagination-container {
        display: inline-flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        padding: 15px 25px;
        background: white;
        border-radius: 12px;
        border: 1px solid #e9ecef;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .pagination {
        display: flex;
        gap: 6px;
        list-style: none;
        padding: 0;
        margin: 0;
        justify-content: center;
    }

    .page-item {
        margin: 0;
    }

    .page-link {
        display: inline-block;
        min-width: 36px;
        padding: 6px 12px;
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 6px;
        color: #0d6e6e;
        text-decoration: none;
        transition: all 0.3s;
        font-size: 14px;
        font-family: 'Cairo', sans-serif;
        text-align: center;
    }

    .page-item.active .page-link {
        background: #0d6e6e;
        color: white;
        border-color: #0d6e6e;
    }

    .page-link:hover:not(.active) {
        background: #e9ecef;
        border-color: #0d6e6e;
        color: #0d6e6e;
        transform: translateY(-1px);
    }

    .page-item.disabled .page-link {
        background: #e9ecef;
        color: #adb5bd;
        cursor: not-allowed;
        opacity: 0.6;
    }

    .pagination-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 20px;
        width: 100%;
        padding-top: 8px;
        border-top: 1px solid #e9ecef;
    }

    .pagination-info {
        font-size: 13px;
        color: #6c757d;
    }

    .page-size-selector {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        color: #6c757d;
    }

    .form-select-sm {
        padding: 4px 8px;
        border-radius: 6px;
        border: 1px solid #dee2e6;
        background: white;
        font-family: 'Cairo', sans-serif;
        cursor: pointer;
        font-size: 13px;
    }

    @@media (max-width: 768px) {
        .pagination-wrapper {
            margin-top: 30px;
            margin-bottom: 20px;
        }

        .pagination-container {
            padding: 12px 15px;
            width: 95%;
        }

        .page-link {
            min-width: 32px;
            padding: 4px 8px;
            font-size: 12px;
        }

        .pagination-footer {
            flex-direction: column;
            gap: 8px;
            text-align: center;
        }

        .pagination-info, .page-size-selector {
            font-size: 11px;
        }
    }
</style>

<script>
    document.getElementById('pageSizeSelect')?.addEventListener('change', function () {
        const pageSize = this.value;
        const url = new URL(window.location.href);
        url.searchParams.set('pageSize', pageSize);
        url.searchParams.set('page', 1);
        window.location.href = url.toString();
    });
</script>