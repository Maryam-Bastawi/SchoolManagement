@using SchoolManagement.Application.DTOs.Bank
@model UpdateBankDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تعديل بيانات البنك";
    Layout = "_Layout";
}

<style>
    .edit-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #b68b40 0%, #9e7536 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #0d6e6e;
            }

    .card-body {
        padding: 30px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group.full-width {
            grid-column: span 2;
        }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
    }

        .control-label i {
            margin-left: 8px;
            color: #b68b40;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #b68b40;
            box-shadow: 0 0 0 3px rgba(182, 139, 64, 0.1);
        }

        .form-control:read-only {
            background-color: #e9ecef;
            opacity: 0.8;
        }

    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: #b68b40;
    }

    .form-check-label {
        cursor: pointer;
        font-weight: 600;
        color: #495057;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-update {
        background: #b68b40;
        color: white;
    }

        .btn-update:hover {
            background: #9e7536;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

    .hint-text {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .readonly-field {
        background-color: #e9ecef;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }

        .button-group {
            flex-direction: column;
        }
    }
</style>
<div class="edit-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-university"></i>
                @ViewData["Title"]
            </h2>
        </div>

        <div class="card-body">
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- Bank Names -->
                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="BankName" class="control-label">
                            <i class="fas fa-language"></i> اسم البنك (عربي) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="BankName" class="form-control" />
                        <span asp-validation-for="BankName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="BankNameEn" class="control-label">
                            <i class="fas fa-language"></i> Bank Name (English) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="BankNameEn" class="form-control" />
                        <span asp-validation-for="BankNameEn" class="text-danger"></span>
                    </div>
                </div>

                <!-- Responsible -->
                <div class="form-row">
                    <div class="form-group full-width">
                        <label asp-for="Responsible" class="control-label">
                            <i class="fas fa-user"></i> المسؤول عن البنك
                        </label>
                        <input asp-for="Responsible" class="form-control"
                               placeholder="أدخل اسم المسؤول عن البنك" />
                        <span asp-validation-for="Responsible" class="text-danger"></span>
                        <div class="hint-text">يمكن ترك هذا الحقل فارغاً إذا لم يتم تحديد مسؤول</div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="button-group">
                    <button type="submit" class="btn btn-update">
                        <i class="fas fa-save"></i> تحديث البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function () {

            // تنبيه لو المستخدم ساب الاسم فاضي
            $('form').on('submit', function () {
                var nameAr = $('#BankName').val();
                var nameEn = $('#BankNameEn').val();

                if (!nameAr || !nameEn) {
                    Swal.fire({
                        title: 'تنبيه',
                        text: 'يجب إدخال اسم البنك بالعربي والإنجليزي',
                        icon: 'warning',
                        confirmButtonColor: '#b68b40'
                    });
                    return false;
                }
            });

        });
    </script>
}