@using SchoolManagement.Application.DTOs.Discount
@model GetDiscountDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تفاصيل الخصم";
    Layout = "_Layout";
}

<style>
    .details-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }


    .details-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #b68b40;
                font-size: 2rem;
            }

    .card-body {
        padding: 30px;
    }

    .info-section {
        margin-bottom: 30px;
    }

    .section-title {
        color: #0d6e6e;
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #e9ecef;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: #b68b40;
        }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }

    .info-item {
        padding: 15px;
        background: #f8f9fa;
        border-radius: 10px;
        border: 1px solid #e9ecef;
    }

    .info-label {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 5px;
        display: flex;
        align-items: center;
        gap: 5px;
    }

        .info-label i {
            color: #0d6e6e;
            width: 20px;
        }

    .info-value {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0d6e6e;
    }

    .info-value-ar {
        font-size: 1.1rem;
        color: #495057;
    }

    .badge-details {
        display: inline-block;
        padding: 8px 16px;
        border-radius: 50px;
        font-weight: 600;
    }

    .badge-active {
        background: #d4edda;
        color: #155724;
    }

    .badge-inactive {
        background: #f8d7da;
        color: #721c24;
    }

    .value-box {
        display: inline-block;
        padding: 8px 16px;
        background: #e9ecef;
        border-radius: 50px;
        font-weight: 700;
    }

    .value-money {
        color: #0d6e6e;
    }

    .value-percent {
        color: #b68b40;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

    .btn-edit {
        background: #b68b40;
        color: white;
    }

        .btn-edit:hover {
            background: #9e7536;
            transform: translateY(-2px);
            color: white;
        }

    .btn-back {
        background: #6c757d;
        color: white;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    @@media (max-width: 768px) {
        .info-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="details-container">
    <div class="details-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-info-circle"></i>
                @ViewData["Title"]
            </h2>
        </div>

        <div class="card-body">
            <div class="info-section">
                <div class="section-title">
                    <i class="fas fa-tag"></i>
                    معلومات الخصم الأساسية
                </div>

                <div class="info-grid">
                    <div class="info-item">
                        <div class="info-label">
                            <i class="fas fa-language"></i>
                            الاسم بالعربية
                        </div>
                        <div class="info-value-ar">@Model.DescountNm</div>
                    </div>

                    <div class="info-item">
                        <div class="info-label">
                            <i class="fas fa-language"></i>
                            الاسم بالإنجليزية
                        </div>
                        <div class="info-value-ar">@Model.DescountNm_E</div>
                    </div>

                  

                    <div class="info-item">
                        <div class="info-label">
                            <i class="fas fa-calculator"></i>
                            قيمة الخصم
                        </div>
                        <div class="info-value">
                            @Model.DiscVal
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">
                            <i class="fas fa-tag"></i>
                            نسبة الخصم
                        </div>
                        <div class="info-value">
                            @Model.DiscPer @("%")
                        </div>
                    </div>
                    <div class="info-item">
                        <div class="info-label">
                            <i class="fas fa-toggle-on"></i>
                            الحالة
                        </div>
                        <div>
                            @if (Model.DiscVal2)
                            {
                                <span class="badge-details badge-active">
                                    <i class="fas fa-check-circle"></i> نشط
                                </span>
                            }
                            else
                            {
                                <span class="badge-details badge-inactive">
                                    <i class="fas fa-times-circle"></i> غير نشط
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <div class="button-group">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-edit">
                    <i class="fas fa-edit"></i>
                    تعديل الخصم
                </a>
                <a asp-action="Index" class="btn btn-back">
                    <i class="fas fa-arrow-right"></i>
                    العودة للقائمة
                </a>
            </div>
        </div>
    </div>
</div>