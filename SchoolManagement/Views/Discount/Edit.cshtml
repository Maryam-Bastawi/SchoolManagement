@using SchoolManagement.Application.DTOs.Discount
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model UpdateDiscountDto

@{
    ViewData["Title"] = "تعديل الخصم";
    Layout = "_Layout";
}

<style>
    /* Edit Page Styles */
    .edit-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }


    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #b68b40 0%, #9a7635 100%);
        color: white;
        padding: 25px 30px;
        position: relative;
        overflow: hidden;
    }

        .card-header::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 50%);
            animation: rotate 15s linear infinite;
        }

    @@keyframes rotate {
        from {
            transform: rotate(0deg);
        }

        to {
            transform: rotate(360deg);
        }
    }

    .card-header h2 {
        margin: 0;
        font-size: 1.8rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        z-index: 1;
    }

        .card-header h2 i {
            color: white;
            font-size: 2rem;
            background: rgba(255,255,255,0.2);
            padding: 10px;
            border-radius: 50%;
        }

    .card-header p {
        margin: 10px 0 0 0;
        opacity: 0.9;
        font-size: 1rem;
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .card-header p span {
            background: rgba(255,255,255,0.2);
            padding: 4px 12px;
            border-radius: 50px;
            font-size: 0.9rem;
            font-weight: 600;
        }

    .card-body {
        padding: 30px;
    }

    .info-box {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .info-box i {
            font-size: 2rem;
            color: #b68b40;
        }

        .info-box p {
            color: #495057;
            font-size: 0.95rem;
            line-height: 1.6;
            margin: 0;
        }

    .discount-id-badge {
        display: inline-block;
        background: #b68b40;
        color: white;
        padding: 5px 15px;
        border-radius: 50px;
        font-size: 0.9rem;
        font-weight: 600;
        margin-top: 8px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

        .control-label i {
            margin-left: 8px;
            color: #b68b40;
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: 'Cairo', sans-serif;
        background-color: #fcfcfc;
    }

        .form-control:focus {
            outline: none;
            border-color: #b68b40;
            box-shadow: 0 0 0 3px rgba(182, 139, 64, 0.1);
            background-color: white;
        }

        .form-control:hover {
            border-color: #0d6e6e;
        }

        .form-control[readonly] {
            background-color: #e9ecef;
            opacity: 0.8;
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .form-check {
        margin: 30px 0;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid #e9ecef;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        margin-left: 10px;
        cursor: pointer;
        accent-color: #b68b40;
    }

    .form-check-label {
        color: #495057;
        font-weight: 600;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-check-label i {
            color: #b68b40;
            font-size: 1.1rem;
        }

    .current-values {
        display: flex;
        gap: 15px;
        margin-bottom: 25px;
        flex-wrap: wrap;
        padding: 15px;
        background: #f0f3f8;
        border-radius: 8px;
    }

    .value-badge {
        background: white;
        border-radius: 50px;
        padding: 8px 20px;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        border: 1px solid #e9ecef;
        box-shadow: 0 2px 5px rgba(0,0,0,0.02);
    }

        .value-badge i {
            color: #b68b40;
            font-size: 1rem;
        }

        .value-badge strong {
            color: #0d6e6e;
            margin-left: 5px;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        border-top: 1px solid #e9ecef;
        padding-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

        .btn i {
            font-size: 1.1rem;
        }

    .btn-save {
        background: #b68b40;
        color: white;
        box-shadow: 0 4px 10px rgba(182, 139, 64, 0.2);
    }

        .btn-save:hover {
            background: #9a7635;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(182, 139, 64, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #0d6e6e;
        color: white;
        box-shadow: 0 4px 10px rgba(13, 110, 110, 0.2);
    }

        .btn-cancel:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    /* Warning Message */
    .warning-message {
        background: #fff3cd;
        border: 1px solid #ffeeba;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 20px;
        color: #856404;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .warning-message i {
            font-size: 1.3rem;
            color: #856404;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .edit-container {
            margin: 15px auto;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h2 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .button-group {
            flex-direction: column;
        }

        .info-box {
            flex-direction: column;
            text-align: center;
        }

        .current-values {
            justify-content: center;
        }
    }
</style>

<div class="edit-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-edit"></i>
                @ViewData["Title"]
            </h2>
            <p>
                <i class="fas fa-hashtag"></i>
                تعديل بيانات الخصم
                <span>#@Model.Id</span>
            </p>
        </div>

        <div class="card-body">
            <!-- Info Box -->
            <div class="info-box">
                <i class="fas fa-pencil-alt"></i>
                <div>
                    <p>
                        <strong>تعديل البيانات:</strong> قم بتعديل البيانات المطلوبة ثم اضغط حفظ.
                        يمكنك تعديل الاسم والقيمة والنسبة حسب الحاجة.
                    </p>
                   
                </div>
            </div>

           @*  <!-- Warning for DiscVal and DiscPer -->
            @if (Model.DiscVal.HasValue && Model.DiscVal > 0 && Model.DiscPer.HasValue && Model.DiscPer > 0)
            {
                <div class="warning-message">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>هذا الخصم يحتوي على قيمة ونسبة معاً. يرجى اختيار واحد فقط.</span>
                </div>
            } *@

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="DescountNm" class="control-label">
                                <i class="fas fa-language"></i> الاسم عربي *
                            </label>
                            <input asp-for="DescountNm" class="form-control"
                                   placeholder="أدخل اسم الخصم بالعربية" />
                            <span asp-validation-for="DescountNm" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="DescountNm_E" class="control-label">
                                <i class="fas fa-language"></i> الاسم إنجليزي *
                            </label>
                            <input asp-for="DescountNm_E" class="form-control"
                                   placeholder="Enter discount name in English" />
                            <span asp-validation-for="DescountNm_E" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="DiscVal" class="control-label">
                                <i class="fas fa-money-bill-wave"></i> قيمة الخصم
                            </label>
                            <input asp-for="DiscVal" class="form-control"
                                   placeholder="أدخل قيمة الخصم (مثلاً: 500)" />
                            <span asp-validation-for="DiscVal" class="text-danger"></span>
                            <small class="text-muted">اترك هذا الحقل فارغاً إذا أردت استخدام نسبة مئوية</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="DiscPer" class="control-label">
                                <i class="fas fa-percent"></i> نسبة الخصم
                            </label>
                            <input asp-for="DiscPer" class="form-control"
                                   placeholder="أدخل نسبة الخصم (مثلاً: 10)" />
                            <span asp-validation-for="DiscPer" class="text-danger"></span>
                            <small class="text-muted">اترك هذا الحقل فارغاً إذا أردت استخدام قيمة ثابتة</small>
                        </div>
                    </div>
                </div>

                <div class="form-check">
                    <input asp-for="DiscVal2" class="form-check-input" />
                    <label asp-for="DiscVal2" class="form-check-label">
                        <i class="fas fa-check-circle"></i> تفعيل الخصم
                    </label>
                    <small class="text-muted me-3">(قم بتفعيل الخصم ليكون متاحاً للاستخدام)</small>
                </div>

                <!-- Current Values Display -->
                @if ((Model.DiscVal.HasValue && Model.DiscVal.Value > 0) ||
                                (Model.DiscPer.HasValue && Model.DiscPer.Value > 0))
                {
                    <div class="current-values">
                        <span class="value-badge">
                            <i class="fas fa-history"></i>
                            <strong>القيم الحالية:</strong>
                        </span>

                        @if (Model.DiscVal.HasValue && Model.DiscVal.Value > 0)
                        {
                            <span class="value-badge">
                                <i class="fas fa-money-bill-wave"></i>
                                القيمة: @Model.DiscVal.Value.ToString("F2")
                            </span>
                        }

                        @if (Model.DiscPer.HasValue && Model.DiscPer.Value > 0)
                        {
                            <span class="value-badge">
                                <i class="fas fa-percent"></i>
                                النسبة: @Model.DiscPer.Value.ToString("0.##")%
                            </span>
                        }
                    </div>
                }

                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ التعديلات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-arrow-right"></i> العودة للقائمة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

