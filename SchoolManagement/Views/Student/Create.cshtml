@model SchoolManagement.Application.DTOs.Student.CreateStudentDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

<!-- Font Awesome للأيقونات -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
@{
    ViewData["Title"] = "اضافة الطلاب";
    Layout = "_Layout";
}

<style>
    /* إضافة RTL للصفحة */
    .create-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px;
        direction: rtl; /* إضافة اتجاه RTL */
        text-align: right; /* محاذاة النص لليمين */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
        border-bottom: none;
        direction: rtl;
    }

        .card-header h4 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
        }

            .card-header h4 i {
                color: #b68b40;
                font-size: 2rem;
            }

    .card-body {
        padding: 30px;
        direction: rtl;
    }

    .form-group {
        margin-bottom: 25px;
        text-align: right;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        text-align: right;
    }

        .control-label i {
            margin-left: 0; /* تعديل المسافة */
            margin-right: 8px; /* إضافة مسافة من اليمين */
            color: #0d6e6e;
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: 'Cairo', sans-serif;
        text-align: right; /* محاذاة النص لليمين */
        direction: rtl; /* اتجاه النص من اليمين لليسار */
    }

        .form-control:focus {
            outline: none;
            border-color: #0d6e6e;
            box-shadow: 0 0 0 3px rgba(13, 110, 110, 0.1);
        }

        .form-control:hover {
            border-color: #b68b40;
        }

        .form-control::placeholder {
            text-align: right; /* محاذاة الـ placeholder لليمين */
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
        text-align: right;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-align: right;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

        .info-note span {
            text-align: right;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
        direction: rtl;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

        .btn i {
            margin-left: 0;
            margin-right: 0;
        }

    .btn-save {
        background: #0d6e6e;
        color: white;
        box-shadow: 0 4px 10px rgba(13, 110, 110, 0.2);
    }

        .btn-save:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        box-shadow: 0 4px 10px rgba(108, 117, 125, 0.2);
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(108, 117, 125, 0.3);
            color: white;
        }

    /* Validation Summary */
    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 25px;
        color: #721c24;
        display: flex;
        align-items: center;
        gap: 10px;
        text-align: right;
        direction: rtl;
    }

        .validation-summary i {
            font-size: 1.2rem;
            color: #721c24;
        }

        .validation-summary ul {
            margin: 0;
            padding-right: 20px;
            text-align: right;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-container {
            margin: 15px auto;
            padding: 0 20px;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h4 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .button-group {
            flex-direction: column;
        }
    }

    /* إضافة خط عربي جميل */
    import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap');

    body {
        font-family: 'Cairo', sans-serif;
        background-color: #f8f9fa;
        margin: 0;
        padding: 0;
    }
</style>

<div class="create-container">
    <div class="form-card">
        <div class="card-header">
            <h4>
                <i class="fas fa-user-graduate"></i>
                إنشاء طالب جديد
            </h4>
        </div>

        <div class="card-body">
            <!-- Info Box -->
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="ModelOnly" class="validation-summary" style="display: none;"></div>

            <form asp-action="Create" method="post">
                <div class="form-group">
                    <label asp-for="FullName" class="control-label">
                        <i class="fas fa-user"></i> الاسم الكامل <span class="text-danger">*</span>
                    </label>
                    <input asp-for="FullName" class="form-control" placeholder="أدخل الاسم الكامل للطالب" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        $(document).ready(function() {
            // إظهار/إخفاء ملخص التحقق إذا كان موجوداً
            if ($('.validation-summary ul').children().length > 0) {
                $('.validation-summary').show();
            }
        });
    </script>
}