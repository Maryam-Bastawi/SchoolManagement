@model SchoolManagement.Application.DTOs.Student.StudentFormViewModel
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تعديل بيانات تعريف الطالب";
    Layout = "_Layout";
}


<style>
    /* تنسيق رفع الصورة */
    .custom-file {
        margin-top: 15px;
    }

    #imagePreview img {
        transition: transform 0.3s ease;
    }

        #imagePreview img:hover {
            transform: scale(1.05);
        }

    .btn-remove-image {
        margin-top: 10px;
        background: #dc3545;
        color: white;
        border: none;
        padding: 5px 15px;
        border-radius: 20px;
        cursor: pointer;
        font-size: 0.8rem;
    }

        .btn-remove-image:hover {
            background: #c82333;
        }
    /* جميع الـ Styles السابقة كما هي */
    .create-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px;
        direction: rtl;
        text-align: right;
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
        border-bottom: none;
        direction: rtl;
    }

        .card-header h4 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
        }

            .card-header h4 i {
                color: #b68b40;
                font-size: 2rem;
            }

    .card-body {
        padding: 30px;
        direction: rtl;
    }

    .form-section {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .form-section-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0d6e6e;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #b68b40;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .form-section-title i {
            color: #b68b40;
        }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -15px;
    }

    .col-md-6 {
        flex: 0 0 50%;
        padding: 0 15px;
        box-sizing: border-box;
    }

    .col-md-4 {
        flex: 0 0 33.333%;
        padding: 0 15px;
        box-sizing: border-box;
    }

    .col-md-12 {
        flex: 0 0 100%;
        padding: 0 15px;
        box-sizing: border-box;
    }

    .form-group {
        margin-bottom: 25px;
        text-align: right;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
        text-align: right;
    }

        .control-label i {
            margin-left: 0;
            margin-right: 8px;
            color: #0d6e6e;
            font-size: 1rem;
        }

    .form-control, select.form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: 'Cairo', sans-serif;
        text-align: right;
        direction: rtl;
        background-color: white;
    }

        .form-control:focus, select.form-control:focus {
            outline: none;
            border-color: #0d6e6e;
            box-shadow: 0 0 0 3px rgba(13, 110, 110, 0.1);
        }

        .form-control:hover, select.form-control:hover {
            border-color: #b68b40;
        }

    .checkbox-group {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-top: 10px;
    }

        .checkbox-group input[type="checkbox"] {
            width: 18px;
            height: 18px;
            cursor: pointer;
        }

        .checkbox-group label {
            margin: 0;
            cursor: pointer;
            font-weight: normal;
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
        text-align: right;
    }

    .field-validation-error {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
        text-align: right;
    }

    .input-validation-error {
        border-color: #dc3545 !important;
        background-color: #fff8f8 !important;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        text-align: right;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
        direction: rtl;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

    .btn-save {
        background: #0d6e6e;
        color: white;
        box-shadow: 0 4px 10px rgba(13, 110, 110, 0.2);
    }

        .btn-save:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        box-shadow: 0 4px 10px rgba(108, 117, 125, 0.2);
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(108, 117, 125, 0.3);
            color: white;
        }

    .required-field::after {
        content: "*";
        color: #dc3545;
        margin-right: 5px;
    }

    @@media (max-width: 768px) {
        .create-container {
            margin: 15px auto;
            padding: 0 20px;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h4 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .col-md-6, .col-md-4 {
            flex: 0 0 100%;
        }

        .button-group {
            flex-direction: column;
        }
    }

    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap');

    body {
        font-family: 'Cairo', sans-serif;
        background-color: #f8f9fa;
        margin: 0;
        padding: 0;
    }

    .btn-toggle-group {
        display: flex;
        gap: 10px;
    }

    .btn-toggle {
        flex: 1;
        padding: 10px 15px;
        border-radius: 10px;
        border: 2px solid #ddd;
        background: #fff;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.25s ease;
        text-align: center;
        user-select: none;
    }

        .btn-toggle:focus,
        .btn-toggle:active {
            outline: none !important;
            box-shadow: none !important;
        }

    /* مهم جدًا */
    .btn-toggle {
        -webkit-appearance: none;
        -moz-appearance: none;
        appearance: none;
    }
        /* Hover */
        .btn-toggle:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(0,0,0,0.08);
        }

        /* Active states */
        .btn-toggle.active-yes {
            background: linear-gradient(135deg, #28a745, #1e7e34);
            color: white;
            border-color: #28a745;
            box-shadow: 0 6px 15px rgba(40,167,69,0.3);
        }

        .btn-toggle.active-no {
            background: linear-gradient(135deg, #dc3545, #b02a37);
            color: white;
            border-color: #dc3545;
            box-shadow: 0 6px 15px rgba(220,53,69,0.3);
        }

        /* Secondary state */
        .btn-toggle.inactive {
            opacity: 0.6;
        }

    /* Smooth animation */
    .btn-toggle {
        position: relative;
        overflow: hidden;
    }
</style>



<div class="create-container">
    <div class="form-card">
        <div class="card-header">
            <h4>
                <i class="fas fa-user-edit"></i>
                تعديل بيانات الطالب
            </h4>
        </div>

        <div class="card-body">
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <form asp-action="Edit" method="post" enctype="multipart/form-data" id="studentForm">
                <input type="hidden" asp-for="Student.Id" />

                <!-- ========== قسم صورة الطالب ========== -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-camera"></i>
                        صورة الطالب
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group text-center">
                                @if (!string.IsNullOrEmpty(Model.Student.StudentImagePath))
                                {
                                    <!-- الصورة الحالية موجودة -->
                                    <div id="currentImagePreview" class="mb-3">
                                        <img id="currentImg" src="@Url.Content(Model.Student.StudentImagePath)" alt="صورة الطالب الحالية"
                                             style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; border: 3px solid #0d6e6e; padding: 3px;" />
                                        <button type="button" class="btn btn-sm btn-danger mt-2" onclick="removeImage()" style="display: block; margin: 5px auto;">
                                            <i class="fas fa-trash"></i> حذف الصورة
                                        </button>
                                    </div>
                                    <div id="imagePreview" class="mb-3" style="display: none;">
                                        <img id="previewImg" src="#" alt="معاينة الصورة الجديدة"
                                             style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; border: 3px solid #0d6e6e; padding: 3px;" />
                                    </div>
                                    <div id="noImagePreview" class="mb-3" style="display: none;">
                                        <div style="width: 150px; height: 150px; border-radius: 50%; background: #e9ecef; display: inline-flex; align-items: center; justify-content: center; border: 3px solid #0d6e6e;">
                                            <i class="fas fa-user-graduate" style="font-size: 4rem; color: #6c757d;"></i>
                                        </div>
                                    </div>
                                }
                                else
                                {
                                    <!-- لا توجد صورة حالية -->
                                    <div id="imagePreview" class="mb-3" style="display: none;">
                                        <img id="previewImg" src="#" alt="معاينة الصورة"
                                             style="width: 150px; height: 150px; object-fit: cover; border-radius: 50%; border: 3px solid #0d6e6e; padding: 3px;" />
                                    </div>
                                    <div id="noImagePreview" class="mb-3">
                                        <div style="width: 150px; height: 150px; border-radius: 50%; background: #e9ecef; display: inline-flex; align-items: center; justify-content: center; border: 3px solid #0d6e6e;">
                                            <i class="fas fa-user-graduate" style="font-size: 4rem; color: #6c757d;"></i>
                                        </div>
                                    </div>
                                }
                                <div class="custom-file">
                                    <input type="file" class="form-control" id="StudentImage" name="StudentImage"
                                           accept="image/*" style="padding: 10px;" />
                                    <small class="text-muted">صيغ مسموحة: JPG, PNG, GIF (الحد الأقصى 2MB)</small>
                                    @if (!string.IsNullOrEmpty(Model.Student.StudentImagePath))
                                    {
                                        <small class="text-info d-block">📸 الصورة الحالية موجودة، يمكنك تغييرها باختيار صورة جديدة</small>
                                    }
                                </div>
                                <span id="imageError" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- القسم الأول: البيانات الأساسية -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-user-circle"></i>
                        البيانات الأساسية
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.FullName" class="control-label required-field">الاسم الكامل</label>
                                <input asp-for="Student.FullName" class="form-control"
                                       placeholder="أدخل الاسم الكامل للطالب"
                                       required
                                       data-val="true"
                                       data-val-required="الاسم الكامل مطلوب" />
                                <span asp-validation-for="Student.FullName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.EnglishName" class="control-label">الاسم باللاتينية</label>
                                <input asp-for="Student.EnglishName" class="form-control"
                                       placeholder="English Name"
                                       dir="ltr" />
                                <span asp-validation-for="Student.EnglishName" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.Gender" class="control-label required-field">النوع</label>
                                <select asp-for="Student.Gender" asp-items="Model.Genders"
                                        class="form-control"
                                        required
                                        data-val="true"
                                        data-val-required="النوع مطلوب">
                                    <option value="">--- اختر النوع ---</option>
                                </select>
                                <span asp-validation-for="Student.Gender" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.NationalId" class="control-label">الجنسية</label>
                                <select asp-for="Student.NationalId" asp-items="Model.Nations" class="form-control">
                                    <option value="">--- اختر الجنسية ---</option>
                                </select>
                                <span asp-validation-for="Student.NationalId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.BirthDate" class="control-label">تاريخ الميلاد</label>
                                <input asp-for="Student.BirthDate" type="date" class="form-control" />
                                <span asp-validation-for="Student.BirthDate" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.BirthPlace" class="control-label">مكان الميلاد</label>
                                <input asp-for="Student.BirthPlace" class="form-control" placeholder="مكان الميلاد" />
                                <span asp-validation-for="Student.BirthPlace" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الثاني: بيانات الاتصال -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-address-card"></i>
                        بيانات الاتصال
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.ResponseName" class="control-label">الشخص المسؤول</label>
                                <input asp-for="Student.ResponseName" class="form-control" placeholder="اسم ولي الأمر" />
                                <span asp-validation-for="Student.ResponseName" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.Mobile" class="control-label">الجوال</label>
                                <input asp-for="Student.Mobile" class="form-control"
                                       placeholder="05xxxxxxxx"
                                       dir="ltr" />
                                <span asp-validation-for="Student.Mobile" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.HomePhone" class="control-label">رقم المنزل</label>
                                <input asp-for="Student.HomePhone" class="form-control" placeholder="رقم المنزل" dir="ltr" />
                                <span asp-validation-for="Student.HomePhone" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.WorkPhone" class="control-label">رقم العمل</label>
                                <input asp-for="Student.WorkPhone" class="form-control" placeholder="رقم العمل" dir="ltr" />
                                <span asp-validation-for="Student.WorkPhone" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.Address" class="control-label">العنوان</label>
                                <textarea asp-for="Student.Address" class="form-control" rows="2" placeholder="العنوان الكامل"></textarea>
                                <span asp-validation-for="Student.Address" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.AreaId" class="control-label">الحي / المنطقة</label>
                                <select asp-for="Student.AreaId" asp-items="Model.Areas" class="form-control">
                                    <option value="">--- اختر الحي ---</option>
                                </select>
                                <span asp-validation-for="Student.AreaId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الثالث: البيانات الدراسية -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-school"></i>
                        البيانات الدراسية
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.SchoolId" class="control-label">المدرسة</label>
                                <select asp-for="Student.SchoolId" asp-items="Model.Schools" class="form-control">
                                    <option value="">--- اختر المدرسة ---</option>
                                </select>
                                <span asp-validation-for="Student.SchoolId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label asp-for="Student.ContractDate" class="control-label">تاريخ الالتحاق</label>
                                <input asp-for="Student.ContractDate" type="date" class="form-control" />
                                <span asp-validation-for="Student.ContractDate" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.StagesId" class="control-label">المرحلة الدراسية</label>
                                <select asp-for="Student.StagesId" asp-items="Model.Stages" class="form-control">
                                    <option value="">--- اختر المرحلة ---</option>
                                </select>
                                <span asp-validation-for="Student.StagesId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.GradesId" class="control-label">الصف</label>
                                <select asp-for="Student.GradesId" asp-items="Model.Grades" class="form-control">
                                    <option value="">--- اختر الصف ---</option>
                                </select>
                                <span asp-validation-for="Student.GradesId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.ClassroomId" class="control-label">الفصل</label>
                                <select asp-for="Student.ClassroomId" asp-items="Model.Classrooms" class="form-control">
                                    <option value="">--- اختر الفصل ---</option>
                                </select>
                                <span asp-validation-for="Student.ClassroomId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الرابع: بيانات إضافية -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-cogs"></i>
                        بيانات إضافية
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.SectionId" class="control-label">القسم</label>
                                <select asp-for="Student.SectionId" asp-items="Model.Sections" class="form-control">
                                    <option value="">--- اختر القسم ---</option>
                                </select>
                                <span asp-validation-for="Student.SectionId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.StudentStatusId" class="control-label">حالة الطالب</label>
                                <select asp-for="Student.StudentStatusId" asp-items="Model.StudentStatuses" class="form-control">
                                    <option value="">--- اختر الحالة ---</option>
                                </select>
                                <span asp-validation-for="Student.StudentStatusId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.TransferTypeId" class="control-label">نوع الانتقال</label>
                                <select asp-for="Student.TransferTypeId" asp-items="Model.TransferTypes" class="form-control">
                                    <option value="">--- اختر النوع ---</option>
                                </select>
                                <span asp-validation-for="Student.TransferTypeId" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.VehicleId" class="control-label">الحافلة</label>
                                <select asp-for="Student.VehicleId" asp-items="Model.Vehicles" class="form-control">
                                    <option value="">--- اختر الحافلة ---</option>
                                </select>
                                <span asp-validation-for="Student.VehicleId" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.Discounttypeid" class="control-label">نوع الخصم</label>
                                <select asp-for="Student.Discounttypeid" asp-items="Model.Discounts" class="form-control">
                                    <option value="">--- اختر الخصم ---</option>
                                </select>
                                <span asp-validation-for="Student.Discounttypeid" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label asp-for="Student.DebtAmount" class="control-label">رصيد الدين</label>
                                <input asp-for="Student.DebtAmount" type="number" step="0.01" class="form-control" placeholder="0.00" />
                                <span asp-validation-for="Student.DebtAmount" class="text-danger"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <!-- Withdraw -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>سحب الملف</label>
                                <div class="btn-toggle-group">
                                    <button type="button" class="btn-toggle" id="btnWithdrawYes"
                                            onclick="setWithdraw(true)">
                                        ✔ سحب
                                    </button>

                                    <button type="button" class="btn-toggle" id="btnWithdrawNo"
                                            onclick="setWithdraw(false)">
                                        ✖ سليم
                                    </button>
                                </div>

                                <input type="hidden" asp-for="Student.IsFileWithdrawn" id="IsFileWithdrawn" />
                            </div>
                        </div>

                        <!-- Date -->
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>تاريخ السحب</label>
                                <input asp-for="Student.WithdrawDate" type="date"
                                       class="form-control" id="WithdrawDate" />
                            </div>
                        </div>

                        <!-- Tax -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>الضريبة</label>

                                <div class="btn-toggle-group">
                                    <button type="button" class="btn-toggle" id="btnTaxYes"
                                            onclick="setTax(true)">
                                        ✔ خاضع
                                    </button>

                                    <button type="button" class="btn-toggle" id="btnTaxNo"
                                            onclick="setTax(false)">
                                        ✖ غير خاضع
                                    </button>
                                </div>

                                <input type="hidden" asp-for="Student.IsTaxable" id="IsTaxable" />
                            </div>
                        </div>

                        <!-- Graduate -->
                        <div class="col-md-4">
                            <div class="form-group">
                                <label>التخرج</label>

                                <div class="btn-toggle-group">
                                    <button type="button" class="btn-toggle" id="btnGradYes"
                                            onclick="setGraduate(true)">
                                        🎓 متخرج
                                    </button>

                                    <button type="button" class="btn-toggle" id="btnGradNo"
                                            onclick="setGraduate(false)">
                                        📌 غير متخرج
                                    </button>
                                </div>
                                <input type="hidden" asp-for="Student.IsGraduate" id="IsGraduate" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- القسم الخامس: ملاحظات -->
                <div class="form-section">
                    <div class="form-section-title">
                        <i class="fas fa-sticky-note"></i>
                        ملاحظات
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label asp-for="Student.Notes" class="control-label">ملاحظات</label>
                                <textarea asp-for="Student.Notes" class="form-control" rows="3" placeholder="ملاحظات ..."></textarea>
                                <span asp-validation-for="Student.Notes" class="text-danger"></span>
                            </div>
                            <div class="form-group">
                                <label asp-for="Student.Notes2" class="control-label">ملاحظات إضافية</label>
                                <textarea asp-for="Student.Notes2" class="form-control" rows="3" placeholder="أي ملاحظات إضافية..."></textarea>
                                <span asp-validation-for="Student.Notes2" class="text-danger"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> تحديث البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>
    <script>
        $(document).ready(function () {
            // تفعيل الـ Validation على الفورم
            $.validator.unobtrusive.parse('#studentForm');

            // تلوين الحقول المطلوبة فقط
            $('input[required], select[required]').each(function () {
                $(this).closest('.form-group').find('.control-label').addClass('required-field');
            });

            // تهيئة حالة الأزرار من قاعدة البيانات
            initializeButtonsFromDatabase();
        });

        // تهيئة الأزرار من القيم المخزنة
        function initializeButtonsFromDatabase() {
            // تهيئة زر السحب
            var isWithdrawn = $('#IsFileWithdrawn').val();
            if (isWithdrawn === 'True') {
                setWithdraw(true);
            } else if (isWithdrawn === 'False') {
                setWithdraw(false);
            }

            // تهيئة زر الضريبة
            var isTaxable = $('#IsTaxable').val();
            if (isTaxable === 'True') {
                setTax(true);
            } else if (isTaxable === 'False') {
                setTax(false);
            }

            // تهيئة زر التخرج
            var isGraduate = $('#IsGraduate').val();
            if (isGraduate === 'True') {
                setGraduate(true);
            } else if (isGraduate === 'False') {
                setGraduate(false);
            }
        }

        function setWithdraw(value) {
            document.getElementById("IsFileWithdrawn").value = value;

            if (value) {
                if (!document.getElementById("WithdrawDate").value) {
                    document.getElementById("WithdrawDate").value = new Date().toISOString().split('T')[0];
                }
            } else {
                document.getElementById("WithdrawDate").value = "";
            }

            toggleButtons("withdraw", value);
            toast("تم تحديث حالة الملف");
        }

        function setTax(value) {
            document.getElementById("IsTaxable").value = value;
            toggleButtons("tax", value);
            toast("تم تحديث حالة الضريبة");
        }

        function setGraduate(value) {
            document.getElementById("IsGraduate").value = value;
            toggleButtons("grad", value);
            toast("تم تحديث حالة التخرج");
        }

        function toggleButtons(type, value) {
            let yesBtn, noBtn;

            if (type === "withdraw") {
                yesBtn = "btnWithdrawYes";
                noBtn = "btnWithdrawNo";
            }
            else if (type === "tax") {
                yesBtn = "btnTaxYes";
                noBtn = "btnTaxNo";
            }
            else if (type === "grad") {
                yesBtn = "btnGradYes";
                noBtn = "btnGradNo";
            }

            const yes = document.getElementById(yesBtn);
            const no = document.getElementById(noBtn);

            if (!yes || !no) return;

            // reset all states
            yes.classList.remove("active-yes", "active-no", "inactive");
            no.classList.remove("active-yes", "active-no", "inactive");

            if (value === true) {
                yes.classList.add("active-yes");
                no.classList.add("inactive");
            } else {
                no.classList.add("active-no");
                yes.classList.add("inactive");
            }
        }

        function toast(msg) {
            let toast = document.createElement("div");
            toast.innerHTML = msg;
            toast.style.position = "fixed";
            toast.style.bottom = "20px";
            toast.style.left = "20px";
            toast.style.background = "#333";
            toast.style.color = "#fff";
            toast.style.padding = "10px 15px";
            toast.style.borderRadius = "8px";
            toast.style.zIndex = 9999;

            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
            }, 2000);
        }
    </script>

    <!-- سكربت معاينة وحذف الصورة -->
    <script>
        // معاينة الصورة قبل الرفع (لـ Edit View)
        const studentImageInput = document.getElementById('StudentImage');
        if (studentImageInput) {
            studentImageInput.addEventListener('change', function (e) {
                const file = e.target.files[0];
                const imageError = document.getElementById('imageError');
                const imagePreview = document.getElementById('imagePreview');
                const noImagePreview = document.getElementById('noImagePreview');
                const previewImg = document.getElementById('previewImg');
                const currentImagePreview = document.getElementById('currentImagePreview');

                // التحقق من وجود ملف
                if (!file) {
                    // إذا كان يوجد صورة حالية، أظهرها
                    if (currentImagePreview) {
                        currentImagePreview.style.display = 'block';
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'none';
                    } else {
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'block';
                    }
                    imageError.textContent = '';
                    return;
                }

                // التحقق من نوع الملف
                const allowedTypes = ['image/jpeg', 'image/jpg', 'image/png', 'image/gif'];
                if (!allowedTypes.includes(file.type)) {
                    imageError.textContent = '❌ صيغة غير مدعومة. يرجى اختيار JPG, PNG أو GIF';
                    if (currentImagePreview) {
                        currentImagePreview.style.display = 'block';
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'none';
                    } else {
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'block';
                    }
                    return;
                }

                // التحقق من حجم الملف (2MB = 2 * 1024 * 1024)
                if (file.size > 2 * 1024 * 1024) {
                    imageError.textContent = '❌ حجم الصورة كبير جداً. الحد الأقصى 2MB';
                    if (currentImagePreview) {
                        currentImagePreview.style.display = 'block';
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'none';
                    } else {
                        imagePreview.style.display = 'none';
                        noImagePreview.style.display = 'block';
                    }
                    return;
                }

                // معاينة الصورة الجديدة
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;

                    // إخفاء الصورة الحالية وإظهار المعاينة
                    if (currentImagePreview) {
                        currentImagePreview.style.display = 'none';
                    }
                    imagePreview.style.display = 'block';
                    noImagePreview.style.display = 'none';
                    imageError.textContent = '✅ تم اختيار صورة جديدة، سيتم استبدال الصورة الحالية';
                    setTimeout(() => {
                        if (imageError.textContent === '✅ تم اختيار صورة جديدة، سيتم استبدال الصورة الحالية') {
                            imageError.textContent = '';
                        }
                    }, 3000);
                };
                reader.readAsDataURL(file);
            });
        }

        // دالة لإزالة الصورة (لـ Edit View)
        function removeImage() {
            const fileInput = document.getElementById('StudentImage');
            const imagePreview = document.getElementById('imagePreview');
            const noImagePreview = document.getElementById('noImagePreview');
            const currentImagePreview = document.getElementById('currentImagePreview');

            // إضافة حقل مخفي للإشارة لحذف الصورة
            let removeImageField = document.querySelector('input[name="RemoveImage"]');
            if (!removeImageField) {
                removeImageField = document.createElement('input');
                removeImageField.type = 'hidden';
                removeImageField.name = 'RemoveImage';
                removeImageField.value = 'true';
                document.getElementById('studentForm').appendChild(removeImageField);
            } else {
                removeImageField.value = 'true';
            }

            // إخفاء الصورة الحالية وإظهار الأيقونة الافتراضية
            if (currentImagePreview) {
                currentImagePreview.style.display = 'none';
            }
            imagePreview.style.display = 'none';
            noImagePreview.style.display = 'block';

            if (fileInput) fileInput.value = '';

            toast('✅ تم حذف الصورة');
        }
    </script>
}