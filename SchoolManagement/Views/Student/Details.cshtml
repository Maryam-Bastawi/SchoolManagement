
@model SchoolManagement.Application.DTOs.Student.CreateStudentDto
@{
    ViewData["Title"] = "تفاصيل الطالب";
    Layout = "_Layout";
}

<!-- Font Awesome للأيقونات -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<style>
    .details-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px;
        direction: rtl;
        text-align: right;
    }

    .details-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
        border-bottom: none;
    }

        .card-header h4 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
        }

            .card-header h4 i {
                color: #b68b40;
                font-size: 2rem;
            }

    .card-body {
        padding: 30px;
    }

    .info-section {
        background: #f8f9fa;
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 25px;
    }

    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #0d6e6e;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 2px solid #b68b40;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .section-title i {
            color: #b68b40;
        }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin: 0 -15px;
    }

    .col-md-6, .col-md-4, .col-md-3 {
        padding: 0 15px;
        box-sizing: border-box;
    }

    .col-md-6 {
        flex: 0 0 50%;
    }

    .col-md-4 {
        flex: 0 0 33.333%;
    }

    .col-md-3 {
        flex: 0 0 25%;
    }

    .info-group {
        margin-bottom: 20px;
    }

    .info-label {
        display: block;
        font-size: 0.8rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 5px;
        font-weight: 600;
    }

        .info-label i {
            margin-left: 0;
            margin-right: 5px;
            color: #0d6e6e;
            font-size: 0.8rem;
        }

    .info-value {
        font-size: 1rem;
        color: #2c3e50;
        font-weight: 500;
        padding: 8px 12px;
        background: white;
        border-radius: 8px;
        border: 1px solid #e9ecef;
        word-break: break-word;
    }

    .badge-status {
        display: inline-block;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .badge-true {
        background-color: #28a745;
        color: white;
    }

    .badge-false {
        background-color: #dc3545;
        color: white;
    }

    .badge-null {
        background-color: #6c757d;
        color: white;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
        direction: rtl;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

    .btn-edit {
        background: #0d6e6e;
        color: white;
    }

        .btn-edit:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            color: white;
        }

    .btn-back {
        background: #6c757d;
        color: white;
    }

        .btn-back:hover {
            background: #5a6268;
            transform: translateY(-2px);
            color: white;
        }

    .student-image {
        text-align: center;
        margin-bottom: 20px;
    }

        .student-image img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #0d6e6e;
            padding: 3px;
        }

        .student-image .no-image {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            background: #e9ecef;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto;
            font-size: 3rem;
            color: #6c757d;
            border: 3px solid #0d6e6e;
        }

    @@media (max-width: 768px) {
        .details-container {
            margin: 15px auto;
            padding: 0 20px;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h4 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .col-md-6, .col-md-4, .col-md-3 {
            flex: 0 0 100%;
        }

        .button-group {
            flex-direction: column;
        }
    }

    @@import url('https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700&display=swap');

    body {
        font-family: 'Cairo', sans-serif;
        background-color: #f8f9fa;
        margin: 0;
        padding: 0;
    }
</style>

<div class="details-container">
    <div class="details-card">
        <div class="card-header">
            <h4>
                <i class="fas fa-user-graduate"></i>
                تفاصيل الطالب
            </h4>
        </div>

        <div class="card-body">
            <!-- صورة الطالب -->
            <div class="student-image">
                @if (!string.IsNullOrEmpty(Model.StudentImagePath))
                {
                    <img src="@Model.StudentImagePath" alt="صورة الطالب" />
                }
                else
                {
                    <div class="no-image">
                        <i class="fas fa-user-graduate"></i>
                    </div>
                }
            </div>

            <!-- القسم الأول: البيانات الأساسية -->
            <div class="info-section">
                <div class="section-title">
                    <i class="fas fa-user-circle"></i>
                    البيانات الأساسية
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-user"></i> الاسم الكامل
                            </div>
                            <div class="info-value">@(Model.FullName ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-language"></i> الاسم باللاتينية
                            </div>
                            <div class="info-value">@(Model.EnglishName ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-venus-mars"></i> النوع
                            </div>
                            <div class="info-value">
                                @if (Model.Gender.ToString() == "Male")
                                {
                                    <span>ذكر</span>
                                }
                                else if (Model.Gender.ToString() == "Female")
                                {
                                    <span>أنثى</span>
                                }
                                else
                                {
                                    <span>@Model.Gender</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-flag"></i> الجنسية
                            </div>
                            <div class="info-value">@(Model.NationalId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-calendar-alt"></i> تاريخ الميلاد
                            </div>
                            <div class="info-value">@(Model.BirthDate?.ToString("yyyy-MM-dd") ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-map-marker-alt"></i> مكان الميلاد
                            </div>
                            <div class="info-value">@(Model.BirthPlace ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- القسم الثاني: بيانات الاتصال -->
            <div class="info-section">
                <div class="section-title">
                    <i class="fas fa-address-card"></i>
                    بيانات الاتصال
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-user-tie"></i> الشخص المسؤول
                            </div>
                            <div class="info-value">@(Model.ResponseName ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-mobile-alt"></i> الجوال
                            </div>
                            <div class="info-value">@(Model.Mobile ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-phone"></i> رقم المنزل
                            </div>
                            <div class="info-value">@(Model.HomePhone ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-briefcase"></i> رقم العمل
                            </div>
                            <div class="info-value">@(Model.WorkPhone ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-home"></i> العنوان
                            </div>
                            <div class="info-value">@(Model.Address ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-city"></i> الحي / المنطقة
                            </div>
                            <div class="info-value">@(Model.AreaId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- القسم الثالث: البيانات الدراسية -->
            <div class="info-section">
                <div class="section-title">
                    <i class="fas fa-school"></i>
                    البيانات الدراسية
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-building"></i> المدرسة
                            </div>
                            <div class="info-value">@(Model.SchoolId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-calendar-check"></i> تاريخ الالتحاق
                            </div>
                            <div class="info-value">@(Model.ContractDate?.ToString("yyyy-MM-dd") ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-layer-group"></i> المرحلة الدراسية
                            </div>
                            <div class="info-value">@(Model.StagesId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-graduation-cap"></i> الصف
                            </div>
                            <div class="info-value">@(Model.GradesId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-chalkboard"></i> الفصل
                            </div>
                            <div class="info-value">@(Model.ClassroomId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- القسم الرابع: بيانات إضافية -->
            <div class="info-section">
                <div class="section-title">
                    <i class="fas fa-cogs"></i>
                    بيانات إضافية
                </div>
                <div class="row">
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-folder"></i> القسم
                            </div>
                            <div class="info-value">@(Model.SectionId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-user-check"></i> حالة الطالب
                            </div>
                            <div class="info-value">@(Model.StudentStatusId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-exchange-alt"></i> نوع الانتقال
                            </div>
                            <div class="info-value">@(Model.TransferTypeId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-bus"></i> الحافلة
                            </div>
                            <div class="info-value">@(Model.VehicleId?.ToString() ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-tags"></i> نوع الخصم
                            </div>
                            <div class="info-value">@(Model.Discounttypeid?.ToString() ?? "—")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-money-bill-wave"></i> رصيد الدين
                            </div>
                            <div class="info-value">@(Model.DebtAmount?.ToString("N2") ?? "0.00")</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-calendar-week"></i> تاريخ العمل
                            </div>
                            <div class="info-value">@(Model.WorkDate ?? "—")</div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-calendar-alt"></i> تسجيل للعام القادم
                            </div>
                            <div class="info-value">
                                @if (Model.RegisterNextYear == true)
                                {
                                    <span class="badge-status badge-true">نعم</span>
                                }
                                else if (Model.RegisterNextYear == false)
                                {
                                    <span class="badge-status badge-false">لا</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-null">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-percent"></i> خاضع للضريبة
                            </div>
                            <div class="info-value">
                                @if (Model.IsTaxable == true)
                                {
                                    <span class="badge-status badge-true">نعم</span>
                                }
                                else if (Model.IsTaxable == false)
                                {
                                    <span class="badge-status badge-false">لا</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-null">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-graduation-cap"></i> هل تخرج؟
                            </div>
                            <div class="info-value">
                                @if (Model.IsGraduate == true)
                                {
                                    <span class="badge-status badge-true">نعم</span>
                                }
                                else if (Model.IsGraduate == false)
                                {
                                    <span class="badge-status badge-false">لا</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-null">—</span>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="info-group">
                            <div class="info-label">
                                <i class="fas fa-folder-open"></i> تم سحب الملف
                            </div>
                            <div class="info-value">
                                @if (Model.IsFileWithdrawn == true)
                                {
                                    <span class="badge-status badge-true">نعم</span>
                                }
                                else if (Model.IsFileWithdrawn == false)
                                {
                                    <span class="badge-status badge-false">لا</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-null">—</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                @if (Model.IsFileWithdrawn == true && Model.WithdrawDate.HasValue)
                {
                    <div class="row">
                        <div class="col-md-12">
                            <div class="info-group">
                                <div class="info-label">
                                    <i class="fas fa-calendar-times"></i> تاريخ السحب
                                </div>
                                <div class="info-value">@Model.WithdrawDate.Value.ToString("yyyy-MM-dd")</div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- القسم الخامس: ملاحظات -->
            @if (!string.IsNullOrEmpty(Model.Notes) || !string.IsNullOrEmpty(Model.Notes2))
            {
                <div class="info-section">
                    <div class="section-title">
                        <i class="fas fa-sticky-note"></i>
                        ملاحظات
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="row">
                            <div class="col-md-12">
                                <div class="info-group">
                                    <div class="info-label">
                                        <i class="fas fa-pencil-alt"></i> ملاحظات
                                    </div>
                                    <div class="info-value">@Model.Notes</div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes2))
                    {
                        <div class="row">
                            <div class="col-md-12">
                                <div class="info-group">
                                    <div class="info-label">
                                        <i class="fas fa-pencil-alt"></i> ملاحظات إضافية
                                    </div>
                                    <div class="info-value">@Model.Notes2</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="button-group">
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-edit">
                    <i class="fas fa-edit"></i> تعديل بيانات الطالب
                </a>
                <a href="@Url.Action("Index", "Student")" class="btn btn-back">
                    <i class="fas fa-arrow-right"></i> العودة للقائمة
                </a>
            </div>
        </div>
    </div>
</div>