@using SchoolManagement.Application.DTOs.CostCenter
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model CreateCostCenterDto

@{
    ViewData["Title"] = "إضافة مركز تكلفة جديدة";
    Layout = "_Layout";
}

<style>
    .create-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #b68b40;
                font-size: 2rem;
            }

        .card-header p {
            margin: 10px 0 0 0;
            opacity: 0.9;
            font-size: 1rem;
        }

    .card-body {
        padding: 30px;
    }

    .info-box {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .info-box i {
            font-size: 2.2rem;
            color: #b68b40;
        }

        .info-box p {
            color: #495057;
            font-size: 1rem;
            line-height: 1.6;
            margin: 0;
        }

    .form-group {
        margin-bottom: 25px;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

        .control-label i {
            margin-left: 8px;
            color: #0d6e6e;
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: 'Cairo', sans-serif;
    }

        .form-control:focus {
            outline: none;
            border-color: #0d6e6e;
            box-shadow: 0 0 0 3px rgba(13, 110, 110, 0.1);
        }

        .form-control:hover {
            border-color: #b68b40;
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .form-check {
        margin: 30px 0;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid #e9ecef;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        margin-left: 10px;
        cursor: pointer;
        accent-color: #0d6e6e;
    }

    .form-check-label {
        color: #495057;
        font-weight: 600;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-check-label i {
            color: #0d6e6e;
            font-size: 1.1rem;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        border-top: 1px solid #e9ecef;
        padding-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

        .btn i {
            font-size: 1.1rem;
        }

    .btn-save {
        background: #0d6e6e;
        color: white;
        box-shadow: 0 4px 10px rgba(13, 110, 110, 0.2);
    }

        .btn-save:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        box-shadow: 0 4px 10px rgba(108, 117, 125, 0.2);
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(108, 117, 125, 0.3);
            color: white;
        }

    /* Validation Summary */
    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 25px;
        color: #721c24;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .validation-summary i {
            font-size: 1.2rem;
            color: #721c24;
        }

        .validation-summary ul {
            margin: 0;
            padding-right: 20px;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-container {
            margin: 15px auto;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h2 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .button-group {
            flex-direction: column;
        }

        .info-box {
            flex-direction: column;
            text-align: center;
        }
    }
</style>
<div class="create-container">
    <div class="form-card">
        <div class="card-header">
            <h2><i class="fas fa-wallet"></i> @ViewData["Title"]</h2>
            <p>أدخل بيانات مركز التكلفة بدقة - الحقول بعلامة * إجبارية</p>
        </div>

        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger"></div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- الاسم عربي -->
                <div class="form-group">
                    <label asp-for="CostNm" class="control-label">
                        <i class="fas fa-language"></i> الاسم عربي *
                    </label>
                    <input asp-for="CostNm" required class="form-control"
                           placeholder="أدخل الاسم بالعربية" />
                    <span asp-validation-for="CostNm" class="text-danger"></span>
                </div>

                <!-- الاسم إنجليزي -->
                <div class="form-group">
                    <label asp-for="CostNme" class="control-label">
                        <i class="fas fa-language"></i> الاسم إنجليزي *
                    </label>
                    <input asp-for="CostNme" required class="form-control"
                           placeholder="Enter name in English" />
                    <span asp-validation-for="CostNme" class="text-danger"></span>
                </div>

                <!-- ملاحظات -->
                <div class="form-group">
                    <label asp-for="Notes" class="control-label">
                        <i class="fas fa-sticky-note"></i> ملاحظات
                    </label>
                    <textarea asp-for="Notes" class="form-control"
                              placeholder="أدخل أي ملاحظات"></textarea>
                    <span asp-validation-for="Notes" class="text-danger"></span>
                </div>

                <!-- الأزرار -->
                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>