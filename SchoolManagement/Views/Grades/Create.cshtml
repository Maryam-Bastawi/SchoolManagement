@using SchoolManagement.Application.DTOs.Grades
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@model CreateGradesDto

@{
    ViewData["Title"] = "إضافة صف جديد";
    Layout = "_Layout";
}

<style>
    .create-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    .card-header {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #b68b40;
                font-size: 2rem;
            }

        .card-header p {
            margin: 10px 0 0 0;
            opacity: 0.9;
            font-size: 1rem;
        }

    .card-body {
        padding: 30px;
    }

    .info-box {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 20px;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .info-box i {
            font-size: 2.2rem;
            color: #b68b40;
        }

        .info-box p {
            color: #495057;
            font-size: 1rem;
            line-height: 1.6;
            margin: 0;
        }

    .form-group {
        margin-bottom: 25px;
    }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
        font-size: 0.95rem;
        text-transform: uppercase;
        letter-spacing: 0.3px;
    }

        .control-label i {
            margin-left: 8px;
            color: #0d6e6e;
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
        font-family: 'Cairo', sans-serif;
    }

        .form-control:focus {
            outline: none;
            border-color: #0d6e6e;
            box-shadow: 0 0 0 3px rgba(13, 110, 110, 0.1);
        }

        .form-control:hover {
            border-color: #b68b40;
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .form-check {
        margin: 30px 0;
        padding: 20px;
        background: #f8f9fa;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 12px;
        border: 1px solid #e9ecef;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        margin-left: 10px;
        cursor: pointer;
        accent-color: #0d6e6e;
    }

    .form-check-label {
        color: #495057;
        font-weight: 600;
        cursor: pointer;
        font-size: 1rem;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .form-check-label i {
            color: #0d6e6e;
            font-size: 1.1rem;
        }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        border-top: 1px solid #e9ecef;
        padding-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        font-family: 'Cairo', sans-serif;
    }

        .btn i {
            font-size: 1.1rem;
        }

    .btn-save {
        background: #0d6e6e;
        color: white;
        box-shadow: 0 4px 10px rgba(13, 110, 110, 0.2);
    }

        .btn-save:hover {
            background: #0a5a5a;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
        box-shadow: 0 4px 10px rgba(108, 117, 125, 0.2);
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(108, 117, 125, 0.3);
            color: white;
        }

    /* Validation Summary */
    .validation-summary {
        background: #f8d7da;
        border: 1px solid #f5c6cb;
        border-radius: 8px;
        padding: 15px 20px;
        margin-bottom: 25px;
        color: #721c24;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .validation-summary i {
            font-size: 1.2rem;
            color: #721c24;
        }

        .validation-summary ul {
            margin: 0;
            padding-right: 20px;
        }

    /* Responsive */
    @@media (max-width: 768px) {
        .create-container {
            margin: 15px auto;
        }

        .card-header {
            padding: 20px;
        }

            .card-header h2 {
                font-size: 1.5rem;
            }

        .card-body {
            padding: 20px;
        }

        .button-group {
            flex-direction: column;
        }

        .info-box {
            flex-direction: column;
            text-align: center;
        }
    }
</style>

<div class="create-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-graduation-cap"></i>
                @ViewData["Title"]
            </h2>
            <p>أدخل بيانات الصف بدقة - الحقول بعلامة * إجبارية</p>
        </div>

        <div class="card-body">
            <!-- Info Box -->
            <div class="info-box">
                <i class="fas fa-info-circle"></i>
                <p>
                    <strong>ملاحظة:</strong> يرجى إدخال بيانات الصف بشكل صحيح لضمان سهولة التعامل
                    مع الرسوم الدراسية وعمليات التصعيد داخل النظام.
                </p>
            </div>

            <!-- Validation Summary -->
            <div asp-validation-summary="All" class="text-danger"></div>

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <!-- ====== المعلومات الأساسية ====== -->
                <div class="section-title">
                    <i class="fas fa-info-circle"></i>
                    <h4>المعلومات الأساسية</h4>
                </div>

                <div class="row">
                    <!-- Grade Name Arabic -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="GradesNm" class="control-label">
                                <i class="fas fa-language"></i> اسم الصف (عربي) *
                            </label>
                            <input asp-for="GradesNm" required class="form-control"
                                   placeholder="أدخل اسم الصف بالعربية" />
                            <span asp-validation-for="GradesNm" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Grade Name English -->
                    <div class="col-md-6">
                        <div class="form-group">
                            <label asp-for="GradesNm_E" class="control-label">
                                <i class="fas fa-language"></i> اسم الصف (إنجليزي) *
                            </label>
                            <input asp-for="GradesNm_E" required class="form-control"
                                   placeholder="Enter grade name in English" />
                            <span asp-validation-for="GradesNm_E" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Stage -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="StagesId" class="control-label">
                                <i class="fas fa-layer-group"></i> المرحلة
                            </label>
                            <select asp-for="StagesId" class="form-control" asp-items="ViewBag.Stages">
                                <option value="">-- اختر المرحلة --</option>
                            </select>
                            <span asp-validation-for="StagesId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- School -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="SchoolId" class="control-label">
                                <i class="fas fa-school"></i> المدرسة
                            </label>
                            <select asp-for="SchoolId" class="form-control" asp-items="ViewBag.Schools">
                                <option value="">-- اختر المدرسة --</option>
                            </select>
                            <span asp-validation-for="SchoolId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Cost Center -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="CostCenterId" class="control-label">
                                <i class="fas fa-chart-line"></i> مركز التكلفة
                            </label>
                            <select asp-for="CostCenterId" class="form-control" asp-items="ViewBag.CostCenters">
                                <option value="">-- اختر مركز التكلفة --</option>
                            </select>
                            <span asp-validation-for="CostCenterId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- ====== الرسوم الدراسية ====== -->
                <div class="section-title">
                    <i class="fas fa-money-bill-wave"></i>
                    <h4>الرسوم الدراسية</h4>
                </div>

                <div class="row">
                    <!-- Term1 Fee -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Term1Fee" class="control-label">
                                <i class="fas fa-dollar-sign"></i> رسوم الفصل الأول
                            </label>
                            <input asp-for="Term1Fee" class="form-control" type="number" step="0.01"
                                   placeholder="0.00" />
                            <span asp-validation-for="Term1Fee" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Term2 Fee -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="Term2Fee" class="control-label">
                                <i class="fas fa-dollar-sign"></i> رسوم الفصل الثاني
                            </label>
                            <input asp-for="Term2Fee" class="form-control" type="number" step="0.01"
                                   placeholder="0.00" />
                            <span asp-validation-for="Term2Fee" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Registration Fee -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="RegistrationFee" class="control-label">
                                <i class="fas fa-file-signature"></i> رسوم التسجيل
                            </label>
                            <input asp-for="RegistrationFee" class="form-control" type="number" step="0.01"
                                   placeholder="0.00" />
                            <span asp-validation-for="RegistrationFee" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Book Fee -->
                    <div class="col-md-3">
                        <div class="form-group">
                            <label asp-for="BookFee" class="control-label">
                                <i class="fas fa-book"></i> رسوم الكتب
                            </label>
                            <input asp-for="BookFee" class="form-control" type="number" step="0.01"
                                   placeholder="0.00" />
                            <span asp-validation-for="BookFee" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <!-- Other Fee -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="OtherFee" class="control-label">
                                <i class="fas fa-plus-circle"></i> رسوم أخرى
                            </label>
                            <input asp-for="OtherFee" class="form-control" type="number" step="0.01"
                                   placeholder="0.00" />
                            <span asp-validation-for="OtherFee" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Transport Cost -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="TransCostId" class="control-label">
                                <i class="fas fa-bus"></i> تكلفة النقل
                            </label>
                            <select asp-for="TransCostId" class="form-control" asp-items="ViewBag.TransCosts">
                                <option value="">-- اختر تكلفة النقل --</option>
                            </select>
                            <span asp-validation-for="TransCostId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- ====== بيانات التصعيد ====== -->
                <div class="section-title">
                    <i class="fas fa-arrow-up"></i>
                    <h4>بيانات التصعيد</h4>
                </div>

                <div class="row">
                    <!-- Next Stage -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="NextStageId" class="control-label">
                                <i class="fas fa-layer-group"></i> المرحلة التالية
                            </label>
                            <select asp-for="NextStageId" class="form-control" asp-items="ViewBag.StagesForNext">
                                <option value="">-- اختر المرحلة التالية --</option>
                            </select>
                            <span asp-validation-for="NextStageId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Next Grade -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="NextGradeId" class="control-label">
                                <i class="fas fa-graduation-cap"></i> الصف التالي
                            </label>
                            <select asp-for="NextGradeId" class="form-control" asp-items="ViewBag.GradesForNext">
                                <option value="">-- اختر الصف التالي --</option>
                            </select>
                            <span asp-validation-for="NextGradeId" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Next School -->
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="NextSchoolId" class="control-label">
                                <i class="fas fa-school"></i> المدرسة التالية
                            </label>
                            <select asp-for="NextSchoolId" class="form-control" asp-items="ViewBag.SchoolsForNext">
                                <option value="">-- اختر المدرسة التالية --</option>
                            </select>
                            <span asp-validation-for="NextSchoolId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- ====== حالة الطالب ====== -->
                <div class="section-title">
                    <i class="fas fa-user-graduate"></i>
                    <h4>حالة الطالب الافتراضية</h4>
                </div>

                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label asp-for="studStatusId" class="control-label">
                                <i class="fas fa-user-check"></i> حالة الطالب
                            </label>
                            <select asp-for="studStatusId" class="form-control" asp-items="ViewBag.StudentStatuses">
                                <option value="">-- اختر حالة الطالب --</option>
                            </select>
                            <span asp-validation-for="studStatusId" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="button-group">
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-save"></i> حفظ البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>