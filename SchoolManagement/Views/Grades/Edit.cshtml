@using SchoolManagement.Application.DTOs.Grades
@model UpdateGradesDto
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تعديل بيانات الصف";
    Layout = "_Layout";
}

<style>
    .edit-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px; /* مسافة بسيطة من الجنب */
    }

    .form-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.05);
        overflow: hidden;
    }

    .card-header {
        background: linear-gradient(135deg, #b68b40 0%, #9e7536 100%);
        color: white;
        padding: 25px 30px;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.8rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 12px;
        }

            .card-header h2 i {
                color: #0d6e6e;
            }

    .card-body {
        padding: 30px;
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 20px;
    }

    .form-group {
        margin-bottom: 20px;
    }

        .form-group.full-width {
            grid-column: span 2;
        }

    .control-label {
        display: block;
        margin-bottom: 8px;
        color: #495057;
        font-weight: 600;
    }

        .control-label i {
            margin-left: 8px;
            color: #b68b40;
        }

    .form-control {
        width: 100%;
        padding: 12px 15px;
        border: 2px solid #e9ecef;
        border-radius: 8px;
        font-size: 1rem;
        transition: all 0.2s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: #b68b40;
            box-shadow: 0 0 0 3px rgba(182, 139, 64, 0.1);
        }

        .form-control:read-only {
            background-color: #e9ecef;
            opacity: 0.8;
        }

    .form-check {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 0;
    }

    .form-check-input {
        width: 20px;
        height: 20px;
        cursor: pointer;
        accent-color: #b68b40;
    }

    .form-check-label {
        cursor: pointer;
        font-weight: 600;
        color: #495057;
    }

    .button-group {
        display: flex;
        gap: 15px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #e9ecef;
    }

    .btn {
        flex: 1;
        padding: 12px 25px;
        border: none;
        border-radius: 8px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        text-decoration: none;
        text-align: center;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .btn-update {
        background: #b68b40;
        color: white;
    }

        .btn-update:hover {
            background: #9e7536;
            transform: translateY(-2px);
        }

    .btn-cancel {
        background: #6c757d;
        color: white;
    }

        .btn-cancel:hover {
            background: #5a6268;
            transform: translateY(-2px);
        }

    .text-danger {
        color: #dc3545;
        font-size: 0.85rem;
        margin-top: 5px;
        display: block;
    }

    .info-note {
        background: #f8f9fa;
        border-right: 4px solid #b68b40;
        border-radius: 8px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .info-note i {
            color: #b68b40;
            font-size: 1.2rem;
        }

    .hint-text {
        font-size: 0.85rem;
        color: #6c757d;
        margin-top: 5px;
    }

    .readonly-field {
        background-color: #e9ecef;
        cursor: not-allowed;
    }

    @@media (max-width: 768px) {
        .form-row {
            grid-template-columns: 1fr;
        }

        .form-group.full-width {
            grid-column: span 1;
        }

        .button-group {
            flex-direction: column;
        }
    }
</style>

<div class="edit-container">
    <div class="form-card">
        <div class="card-header">
            <h2>
                <i class="fas fa-graduation-cap"></i>
                @ViewData["Title"]
            </h2>
            <p>تعديل بيانات الصف الدراسي</p>
        </div>

        <div class="card-body">
            <div class="info-note">
                <i class="fas fa-info-circle"></i>
                <span>الحقول بعلامة <span class="text-danger">*</span> إجبارية</span>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <!-- ====== المعلومات الأساسية ====== -->
                <div class="section-title">
                    <i class="fas fa-info-circle"></i>
                    <h4>المعلومات الأساسية</h4>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="GradesNm" class="control-label">
                            <i class="fas fa-language"></i> اسم الصف (عربي) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="GradesNm" class="form-control" 
                               placeholder="أدخل اسم الصف بالعربية" />
                        <span asp-validation-for="GradesNm" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="GradesNm_E" class="control-label">
                            <i class="fas fa-language"></i> Grade Name (English) <span class="text-danger">*</span>
                        </label>
                        <input asp-for="GradesNm_E" class="form-control" 
                               placeholder="Enter grade name in English" />
                        <span asp-validation-for="GradesNm_E" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="StagesId" class="control-label">
                            <i class="fas fa-layer-group"></i> المرحلة
                        </label>
                        <select asp-for="StagesId" class="form-control" asp-items="ViewBag.Stages">
                            <option value="">-- اختر المرحلة --</option>
                        </select>
                        <span asp-validation-for="StagesId" class="text-danger"></span>
                        <div class="hint-text">اختر المرحلة التعليمية المناسبة</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="SchoolId" class="control-label">
                            <i class="fas fa-school"></i> المدرسة
                        </label>
                        <select asp-for="SchoolId" class="form-control" asp-items="ViewBag.Schools">
                            <option value="">-- اختر المدرسة --</option>
                        </select>
                        <span asp-validation-for="SchoolId" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="CostCenterId" class="control-label">
                            <i class="fas fa-chart-line"></i> مركز التكلفة
                        </label>
                        <select asp-for="CostCenterId" class="form-control" asp-items="ViewBag.CostCenters">
                            <option value="">-- اختر مركز التكلفة --</option>
                        </select>
                        <span asp-validation-for="CostCenterId" class="text-danger"></span>
                    </div>
                </div>

                <!-- ====== الرسوم الدراسية ====== -->
                <div class="section-title">
                    <i class="fas fa-money-bill-wave"></i>
                    <h4>الرسوم الدراسية</h4>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Term1Fee" class="control-label">
                            <i class="fas fa-dollar-sign"></i> رسوم الفصل الأول
                        </label>
                        <input asp-for="Term1Fee" class="form-control" type="number" step="0.01"
                               placeholder="0.00" />
                        <span asp-validation-for="Term1Fee" class="text-danger"></span>
                        <div class="hint-text">قيمة رسوم الفصل الدراسي الأول</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="Term2Fee" class="control-label">
                            <i class="fas fa-dollar-sign"></i> رسوم الفصل الثاني
                        </label>
                        <input asp-for="Term2Fee" class="form-control" type="number" step="0.01"
                               placeholder="0.00" />
                        <span asp-validation-for="Term2Fee" class="text-danger"></span>
                        <div class="hint-text">قيمة رسوم الفصل الدراسي الثاني</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="RegistrationFee" class="control-label">
                            <i class="fas fa-file-signature"></i> رسوم التسجيل
                        </label>
                        <input asp-for="RegistrationFee" class="form-control" type="number" step="0.01"
                               placeholder="0.00" />
                        <span asp-validation-for="RegistrationFee" class="text-danger"></span>
                        <div class="hint-text">رسوم القيد والتسجيل</div>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="BookFee" class="control-label">
                            <i class="fas fa-book"></i> رسوم الكتب
                        </label>
                        <input asp-for="BookFee" class="form-control" type="number" step="0.01"
                               placeholder="0.00" />
                        <span asp-validation-for="BookFee" class="text-danger"></span>
                        <div class="hint-text">رسوم الكتب المدرسية</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="OtherFee" class="control-label">
                            <i class="fas fa-plus-circle"></i> رسوم أخرى
                        </label>
                        <input asp-for="OtherFee" class="form-control" type="number" step="0.01"
                               placeholder="0.00" />
                        <span asp-validation-for="OtherFee" class="text-danger"></span>
                        <div class="hint-text">أي رسوم إضافية أخرى</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="TransCostId" class="control-label">
                            <i class="fas fa-bus"></i> تكلفة النقل
                        </label>
                        <select asp-for="TransCostId" class="form-control" asp-items="ViewBag.TransCosts">
                            <option value="">-- اختر تكلفة النقل --</option>
                        </select>
                        <span asp-validation-for="TransCostId" class="text-danger"></span>
                    </div>
                </div>

                <!-- ====== بيانات التصعيد ====== -->
                <div class="section-title">
                    <i class="fas fa-arrow-up"></i>
                    <h4>بيانات التصعيد</h4>
                    <span class="hint-text-inline">(اختياري - للترقية إلى مرحلة أعلى)</span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="NextStageId" class="control-label">
                            <i class="fas fa-layer-group"></i> المرحلة التالية
                        </label>
                        <select asp-for="NextStageId" class="form-control" asp-items="ViewBag.StagesForNext">
                            <option value="">-- اختر المرحلة التالية --</option>
                        </select>
                        <span asp-validation-for="NextStageId" class="text-danger"></span>
                        <div class="hint-text">المرحلة التي ينتقل إليها الطالب بعد التخرج</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="NextGradeId" class="control-label">
                            <i class="fas fa-graduation-cap"></i> الصف التالي
                        </label>
                        <select asp-for="NextGradeId" class="form-control" asp-items="ViewBag.GradesForNext">
                            <option value="">-- اختر الصف التالي --</option>
                        </select>
                        <span asp-validation-for="NextGradeId" class="text-danger"></span>
                        <div class="hint-text">الصف الذي ينتقل إليه الطالب بعد التخرج</div>
                    </div>

                    <div class="form-group">
                        <label asp-for="NextSchoolId" class="control-label">
                            <i class="fas fa-school"></i> المدرسة التالية
                        </label>
                        <select asp-for="NextSchoolId" class="form-control" asp-items="ViewBag.SchoolsForNext">
                            <option value="">-- اختر المدرسة التالية --</option>
                        </select>
                        <span asp-validation-for="NextSchoolId" class="text-danger"></span>
                        <div class="hint-text">المدرسة التي ينتقل إليها الطالب بعد التخرج</div>
                    </div>
                </div>

                <!-- ====== حالة الطالب ====== -->
                <div class="section-title">
                    <i class="fas fa-user-graduate"></i>
                    <h4>حالة الطالب الافتراضية</h4>
                </div>

                <div class="form-row">
                    <div class="form-group full-width">
                        <label asp-for="studStatusId" class="control-label">
                            <i class="fas fa-user-check"></i> حالة الطالب
                        </label>
                        <select asp-for="studStatusId" class="form-control" asp-items="ViewBag.StudentStatuses">
                            <option value="">-- اختر حالة الطالب --</option>
                        </select>
                        <span asp-validation-for="studStatusId" class="text-danger"></span>
                        <div class="hint-text">الحالة الافتراضية للطلاب المسجلين في هذا الصف</div>
                    </div>
                </div>

                <!-- Summary Card -->
                <div class="summary-card">
                    <div class="summary-title">
                        <i class="fas fa-chart-pie"></i>
                        <h5>ملخص الرسوم</h5>
                    </div>
                    <div class="summary-content">
                        <div class="summary-item">
                            <span>إجمالي رسوم الفصلين:</span>
                            <strong id="totalFees">0.00</strong>
                        </div>
                        <div class="summary-item">
                            <span>إجمالي الرسوم الكلية:</span>
                            <strong id="grandTotal">0.00</strong>
                        </div>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="button-group">
                    <button type="submit" class="btn btn-update">
                        <i class="fas fa-save"></i> تحديث البيانات
                    </button>
                    <a asp-action="Index" class="btn btn-cancel">
                        <i class="fas fa-times"></i> إلغاء والعودة
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            calculateTotalFees();

            // Calculate total fees on input change
            $('#Term1Fee, #Term2Fee, #RegistrationFee, #BookFee, #OtherFee').on('input', function () {
                calculateTotalFees();
            });

            // Validation before submit
            $('form').on('submit', function (e) {
                var nameAr = $('#GradesNm').val();
                var nameEn = $('#GradesNm_E').val();

                if (!nameAr || !nameEn) {
                    Swal.fire({
                        title: 'تنبيه',
                        text: 'يجب إدخال اسم الصف بالعربي والإنجليزي',
                        icon: 'warning',
                        confirmButtonColor: '#667eea'
                    });
                    e.preventDefault();
                    return false;
                }

                // Check if fees are valid numbers
                var fees = ['Term1Fee', 'Term2Fee', 'RegistrationFee', 'BookFee', 'OtherFee'];
                for (var i = 0; i < fees.length; i++) {
                    var value = $('#' + fees[i]).val();
                    if (value && isNaN(parseFloat(value))) {
                        Swal.fire({
                            title: 'خطأ',
                            text: 'قيمة الرسوم يجب أن تكون رقماً صحيحاً',
                            icon: 'error',
                            confirmButtonColor: '#667eea'
                        });
                        e.preventDefault();
                        return false;
                    }
                }
            });

            // Calculate total fees function
            function calculateTotalFees() {
                var term1 = parseFloat($('#Term1Fee').val()) || 0;
                var term2 = parseFloat($('#Term2Fee').val()) || 0;
                var registration = parseFloat($('#RegistrationFee').val()) || 0;
                var book = parseFloat($('#BookFee').val()) || 0;
                var other = parseFloat($('#OtherFee').val()) || 0;

                var totalFees = term1 + term2;
                var grandTotal = totalFees + registration + book + other;

                $('#totalFees').text(totalFees.toFixed(2));
                $('#grandTotal').text(grandTotal.toFixed(2));
            }
        });
    </script>
}