@model SchoolManagement.Application.DTOs.RegistrationStudent.RegistrationIndexVM
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@{
    ViewData["Title"] = "تسجيلات الطلاب";
    Layout = "_Layout";
}

<style>
    .index-container {
        width: 100%;
        max-width: 100%;
        margin: 30px 0;
        padding: 0 40px;
    }

    .header-card {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        border-radius: 15px;
        padding: 30px;
        margin-bottom: 30px;
        color: white;
        box-shadow: 0 5px 25px rgba(0, 0, 0, 0.1);
    }

    .header-title h1 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 12px;
    }

        .header-title h1 i {
            color: #b68b40;
            font-size: 2.2rem;
        }

    .header-title p {
        margin: 5px 0 0 0;
        opacity: 0.9;
        font-size: 0.9rem;
    }

    /* بطاقة التسجيل الجديد */
    .register-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #e9ecef;
        margin-bottom: 30px;
    }

    .card-header-custom {
        background: #f8f9fa;
        padding: 20px 25px;
        border-bottom: 2px solid #0d6e6e;
    }

        .card-header-custom h4 {
            margin: 0;
            color: #0d6e6e;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 10px;
        }

    .card-body-custom {
        padding: 30px;
    }

    /* جدول التسجيلات */
    .table-card {
        background: white;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #e9ecef;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background: #f8f9fa;
        color: #0d6e6e;
        font-weight: 700;
        padding: 15px;
        text-align: center;
        border-bottom: 2px solid #0d6e6e;
    }

    td {
        padding: 12px;
        text-align: center;
        border-bottom: 1px solid #e9ecef;
    }

    tr:hover td {
        background: #f8f9fa;
    }

    .badge-paid {
        background: #28a745;
        color: white;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

    .badge-unpaid {
        background: #ffc107;
        color: #333;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.8rem;
    }

    .action-buttons {
        display: flex;
        gap: 5px;
        justify-content: center;
    }

    .btn-action {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        color: white;
        text-decoration: none;
        border: none;
        cursor: pointer;
    }

    .btn-view {
        background: #17a2b8;
    }

    .btn-delete {
        background: #dc3545;
    }

    .btn-start {
        background: linear-gradient(135deg, #0d6e6e 0%, #0a5a5a 100%);
        color: white;
        padding: 12px 30px;
        border-radius: 50px;
        border: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        transition: all 0.3s ease;
    }

        .btn-start:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(13, 110, 110, 0.3);
            color: white;
        }

    .form-group {
        margin-bottom: 20px;
    }

    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
        display: block;
    }

        .form-label i {
            color: #0d6e6e;
            margin-left: 8px;
        }

    .form-control, .select2-container--bootstrap-5 .select2-selection {
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 10px 15px;
        transition: all 0.2s ease;
    }

    .alert {
        padding: 15px 20px;
        border-radius: 10px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: slideDown 0.3s ease;
    }

    .alert-success {
        background: #d4edda;
        border-right: 4px solid #155724;
        color: #155724;
    }

    .alert-danger {
        background: #f8d7da;
        border-right: 4px solid #721c24;
        color: #721c24;
    }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: white;
        border-radius: 12px;
        border: 2px dashed #e9ecef;
    }

        .empty-state i {
            font-size: 4rem;
            color: #b68b40;
            opacity: 0.5;
        }

    .search-box {
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 10px;
    }

        .search-box input {
            width: 300px;
            padding: 10px 15px;
            border: 2px solid #e9ecef;
            border-radius: 50px;
        }

    @@keyframes slideDown {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 768px) {
        .index-container {
            padding: 0 15px;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .search-box {
            flex-direction: column;
        }

            .search-box input {
                width: 100%;
            }
    }
</style>

<div class="index-container">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            <i class="fas fa-check-circle"></i> @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
        </div>
    }

    <!-- Header -->
    <div class="header-card">
        <div class="header-title">
            <h1>
                <i class="fas fa-user-graduate"></i>
                تسجيلات الطلاب
            </h1>
            <p>إدارة تسجيلات الطلاب في السنوات الدراسية</p>
        </div>
    </div>

    <!-- بطاقة تسجيل طالب جديد -->
    <div class="register-card">
        <div class="card-header-custom">
            <h4>
                <i class="fas fa-plus-circle"></i>
                تسجيل طالب جديد
            </h4>
        </div>
        <div class="card-body-custom">
            <form asp-action="Index" asp-controller="RegistrationStudent" method="post">
                @Html.AntiForgeryToken()

                <div class="row">
                    <div class="col-md-5">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-user"></i> الطالب
                            </label>
                            <select asp-for="SelectedStudentId" asp-items="Model.StudentsList"
                                    class="form-control select2" style="width: 100%">
                                <option value="">-- اختر الطالب --</option>
                            </select>
                            <span asp-validation-for="SelectedStudentId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="fas fa-calendar-alt"></i> العام الدراسي
                            </label>
                            <select asp-for="SelectedStudyYearId" asp-items="Model.StudyYearsList"
                                    class="form-control">
                                <option value="">-- اختر العام الدراسي --</option>
                            </select>
                            <span asp-validation-for="SelectedStudyYearId" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="form-group">
                            <label class="form-label" style="visibility: hidden;">.</label>
                            <button type="submit" class="btn-start w-100">
                                <i class="fas fa-arrow-left"></i> بدء التسجيل
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- قائمة التسجيلات -->
    <div class="search-box">
        <input type="text" id="searchInput" placeholder="🔍 بحث بالاسم أو المدرسة أو العام الدراسي...">
        <div>
            <span class="text-muted">عدد التسجيلات: @(Model.Registrations?.Count ?? 0)</span>
        </div>
    </div>

    @if (Model.Registrations == null || !Model.Registrations.Any())
    {
        <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <h3>لا توجد تسجيلات</h3>
            <p>لم يتم تسجيل أي طالب بعد. استخدم النموذج أعلاه لتسجيل طالب جديد.</p>
        </div>
    }
    else
    {
        <div class="table-card">
            <div class="table-responsive">
                <table id="registrationsTable">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>الطالب</th>
                            <th>المدرسة</th>
                            <th>المرحلة</th>
                            <th>الصف</th>
                            <th>العام الدراسي</th>
                            <th>إجمالي الرسوم</th>
                            <th>المبلغ النهائي</th>
                            <th>حالة الدفع</th>
                            <th>تاريخ التسجيل</th>
                            <th>الإجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Registrations.Select((value, i) => new { i = i + 1, value }))
                        {
                            <tr>
                                <td>@item.i</td>
                                <td class="fw-bold">@item.value.Student?.FullName</td>
                                <td>@item.value.Student?.School?.SchoolNm</td>
                                <td>@item.value.Student?.stages?.StageNM</td>
                                <td>@item.value.Student?.Grades?.GradesNm</td>
                                <td>@item.value.StudyYear?.StudyYearsNm</td>
                                <td>@(item.value.TotalAmount?.ToString("N2") ?? "0.00")</td>
                                <td class="fw-bold text-success">@(item.value.AmountAfterDiscount?.ToString("N2") ?? "0.00")</td>
                                <td>
                                    @if (item.value.IsPaid)
                                    {
                                        <span class="badge-paid">مدفوع</span>
                                    }
                                    else
                                    {
                                        <span class="badge-unpaid">غير مدفوع</span>
                                    }
                                </td>
                                <td>@(item.value.RegistrationDate?.ToString("yyyy/MM/dd"))</td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-action="Details" asp-route-id="@item.value.Id" class="btn-action btn-view" title="تفاصيل">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.value.Id" method="post" style="display:inline;"
                                              onsubmit="return confirm('هل أنت متأكد من حذف هذا التسجيل؟')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn-action btn-delete" title="حذف">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script>
        $(document).ready(function() {
            setTimeout(function() {
                $('.alert').fadeOut('slow');
            }, 5000);

            // تهيئة Select2
            $('.select2').select2({
                placeholder: "اختر العام الدراسي أولاً...",
                allowClear: true,
                theme: 'bootstrap-5',
                language: {
                    searching: function() { return "جاري البحث..."; },
                    noResults: function() { return "لا توجد نتائج"; }
                }
            });

            // تعطيل دروب داون الطالب في البداية
            $('#SelectedStudentId').prop('disabled', true);
            $('#SelectedStudentId').empty().append('<option value="">-- اختر العام الدراسي أولاً --</option>');

            // عند تغيير العام الدراسي
            $('#SelectedStudyYearId').on('change', function() {
                var studyYearId = $(this).val();
                var $studentSelect = $('#SelectedStudentId');

                if (studyYearId) {
                    // تعطيل السليكت أثناء التحميل
                    $studentSelect.prop('disabled', true);
                    $studentSelect.empty().append('<option value="">جاري تحميل الطلاب...</option>');

                    $.ajax({
                        url: '@Url.Action("GetUnregisteredStudents", "RegistrationStudent")',
                        type: 'GET',
                        data: { studyYearId: studyYearId },
                        success: function(data) {
                            $studentSelect.empty();

                            if (data.length === 0) {
                                $studentSelect.append('<option value="" disabled>⚠️ لا يوجد طلاب غير مسجلين في هذا العام</option>');
                                // تعطيل زر الإرسال
                                $('button[type="submit"]').prop('disabled', true);
                            } else {
                                $studentSelect.append('<option value="">-- اختر الطالب --</option>');
                                $.each(data, function(index, student) {
                                    $studentSelect.append('<option value="' + student.value + '">' + student.text + '</option>');
                                });
                                $('button[type="submit"]').prop('disabled', false);
                            }

                            $studentSelect.prop('disabled', false);
                            // إعادة تهيئة Select2
                            $studentSelect.trigger('change');
                        },
                        error: function() {
                            $studentSelect.empty();
                            $studentSelect.append('<option value="">حدث خطأ في تحميل البيانات</option>');
                            $studentSelect.prop('disabled', false);
                        }
                    });
                } else {
                    $studentSelect.empty();
                    $studentSelect.append('<option value="">-- اختر العام الدراسي أولاً --</option>');
                    $studentSelect.prop('disabled', true);
                    $('button[type="submit"]').prop('disabled', true);
                }
            });

            // تفعيل البحث في الجدول
            $("#searchInput").on("keyup", function() {
                var value = $(this).val().toLowerCase();
                $("#registrationsTable tbody tr").filter(function() {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1)
                });
            });
        });
    </script>
}