@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js"></script>
    <script>
        $(document).ready(function() {
            // Initialize WOW.js for scroll animations
            new WOW({
                mobile: false,
                offset: 100
            }).init();

            // Smooth scroll for anchor links
            $('a[href*="#"]').on('click', function(e) {
                e.preventDefault();

                if (this.hash !== '') {
                    const hash = this.hash;

                    $('html, body').animate({
                        scrollTop: $(hash).offset().top - 80
                    }, 800, 'swing');
                }
            });

            // Navbar background change on scroll
            $(window).on('scroll', function() {
                if ($(window).scrollTop() > 100) {
                    $('.navbar').addClass('navbar-scrolled');
                } else {
                    $('.navbar').removeClass('navbar-scrolled');
                }
            });

            // Form submission
            $('#contactForm').on('submit', function(e) {
                e.preventDefault();

                // Show success message (you can replace with actual AJAX submission)
                Swal.fire({
                    title: 'تم الإرسال',
                    text: 'شكراً لتواصلك معنا، سنرد عليك في أقرب وقت',
                    icon: 'success',
                    confirmButtonColor: '#0d6e6e',
                    confirmButtonText: 'حسناً'
                });

                this.reset();
            });

            // Counter animation for stats
            function animateStats() {
                $('.stat-number').each(function() {
                    const $this = $(this);
                    const target = parseInt($this.text().replace(/[^0-9]/g, ''));

                    if (!isNaN(target)) {
                        $({ Counter: 0 }).animate({ Counter: target }, {
                            duration: 2000,
                            easing: 'swing',
                            step: function() {
                                $this.text(Math.ceil(this.Counter) + '+');
                            }
                        });
                    }
                });
            }

            // Trigger stats animation when in viewport
            $(window).on('scroll', function() {
                const statsTop = $('.stats-section').offset().top - $(window).height() + 200;

                if ($(window).scrollTop() > statsTop && !$('.stats-section').hasClass('animated')) {
                    $('.stats-section').addClass('animated');
                    animateStats();
                }
            });

            // Trigger if already in viewport on page load
            if ($(window).scrollTop() + $(window).height() > $('.stats-section').offset().top) {
                if (!$('.stats-section').hasClass('animated')) {
                    $('.stats-section').addClass('animated');
                    animateStats();
                }
            }
        });
    </script>

    <!-- Add some extra styles for navbar -->
    <style>
        /* Navbar scroll effect */
        .navbar {
            transition: all 0.3s ease;
            background: transparent !important;
            padding: 20px 0;
        }

        .navbar-scrolled {
            background: var(--primary-color) !important;
            padding: 10px 0;
            box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
        }

        .navbar-dark .navbar-nav .nav-link {
